@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var username = HttpContextAccessor.HttpContext?.Session.GetString("username");
    var role = HttpContextAccessor.HttpContext?.Session.GetString("role");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Thu ngân</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Lobster&family=Orbitron&display=swap" rel="stylesheet" />

    <style>
        body {
 
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            color: #eee;
            font-family: 'Orbitron', sans-serif;
            padding-top: 70px;
        }


        .navbar {
            background-color: #121212;
            border-bottom: 2px solid #00ffaa;
            box-shadow: 0 0 10px #00ffaa44;
        }

        .navbar-brand {
            font-family: 'Lobster', cursive;
            font-size: 28px;
            color: #00ffaa !important;
            text-shadow: 0 0 10px #00ffaa;
        }

        .nav-link {
            color: #fff !important;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: #00ffaa !important;
                text-shadow: 0 0 6px #00ffaa;
            }

        .btn-logout {
            background-color: #ff4d4d;
            color: white;
            border: none;
            padding: 6px 12px;
            border-radius: 5px;
            font-weight: bold;
            transition: 0.3s;
        }

            .btn-logout:hover {
                background-color: #cc0000;
                box-shadow: 0 0 10px red;
            }

        .footer {
            margin-top: 60px;
            padding: 20px;
            font-size: 14px;
            color: #aaa;
            text-align: center;
            border-top: 1px solid #333;
        }

        #bg-video {
            position: fixed;
            top: 0;
            left: 0;
            min-width: 100%;
            min-height: 100%;
            object-fit: cover;
            z-index: -1;
        }

        .content {
            position: relative;
            z-index: 1;
            color: #fff;
            text-align: center;
        }

    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Cashier">💰 Zanee Cashier</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="/Cashier">🏠 Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Cashier" asp-controller="Booking" asp-action="Index">📦 Đơn đặt</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="Cashier" asp-controller="Invoice" asp-action="Index">🧾 Hóa đơn</a></li>
                    @if (!string.IsNullOrEmpty(username))
                    {
                        <li class="nav-item"><span class="nav-link">👤 @username (CASHIER)</span></li>
                        <li class="nav-item">
                            <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/Cashier/Dashboard">
                                <button type="submit" class="btn btn-danger nav-link text-white border-0">
                                    <i class="fas fa-sign-out-alt me-1"></i> Đăng xuất
                                </button>
                            </form>

                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <video autoplay muted loop id="bg-video">
        <source src="/images/4.mp4" type="video/mp4">
        Trình duyệt của bạn không hỗ trợ video.
    </video>
    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="footer">
        © 2025 Zanee's Music Studio - Khu vực Thu ngân
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
