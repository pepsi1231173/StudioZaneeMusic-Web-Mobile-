@page "/Rooms/Lich-trong"
@model DuAnBai3.Pages.Rooms.Lich_trongModel
@{
    ViewData["Title"] = "Lịch Trống Phòng Studio";
    Layout = "~/Areas/Identity/Pages/Shared/_Layout.cshtml";
}

<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <style>
        body {
            background: url('/images/room_rental.gif') no-repeat center center fixed;
            background-size: cover;
            color: white;
            font-family: 'Poppins', sans-serif;
            margin-top: 50px;
            margin-bottom: 50px;
        }

        .container {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(10px);
        }

        .table th, .table td {
            text-align: center;
            vertical-align: middle;
        }

        .available {
            background-color: #28a745 !important;
            color: white;
        }

        .pending {
            background-color: #ffc107 !important;
            color: black;
        }

        .booked {
            background-color: #dc3545 !important;
            color: white;
        }

        .active {
            background-color: #fd7e14 !important;
            color: white;
        }

        .passed {
            background-color: #0d6efd !important;
            color: white;
        }

        .maintenance {
            background-color: gray !important;
            color: white;
            cursor: not-allowed;
        }
    </style>
</head>

<div class="container">
    <h2 class="text-center mb-4">📅 Lịch Trống Phòng Studio</h2>

    <div class="text-center mb-4">
        <label for="roomSelect" class="fw-bold me-2">🔎 Chọn phòng:</label>
        <select id="roomSelect" class="form-select w-auto d-inline" onchange="changeRoom()">
            @foreach (var room in Model.Rooms)
            {
                <option value="@room" selected="@(room == Model.SelectedRoom ? "selected" : null)">Phòng @room</option>
            }
        </select>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex flex-wrap" style="gap: 0.5rem;">
            <span class="badge bg-success">🟩 Chưa đặt</span>
            <span class="badge bg-warning text-dark">🟨 Chờ duyệt</span>
            <span class="badge bg-danger">🟥 Đã đặt</span>
            <span class="badge text-white" style="background-color:#fd7e14;">🟧 Đang sử dụng</span>
            <span class="badge bg-primary">🟦 Đã qua</span>
            <span class="badge bg-secondary">⬜ Đang bảo trì</span>
        </div>
        <h3 class="m-0">📍 Phòng @Model.SelectedRoom</h3>
        <p id="currentTime" class="m-0">⏳ Đang tải thời gian...</p>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-light text-dark">
            <tr>
                <th>Giờ</th>
                @foreach (var day in Model.Days)
                {
                    <th>@day.ToString("dd/MM")</th>
                }
            </tr>
        </thead>
        <tbody>
            @for (int hour = 8; hour <= 21; hour++)
            {
                <tr>
                    <td class="fw-bold">@hour:00</td>
                    @foreach (var day in Model.Days)
                    {
                        var status = Model.GetBookingStatus(day, hour) ?? "";
                        var statusText = status switch
                        {
                            "pending" => "Chờ duyệt",
                            "booked" => "Đã đặt",
                            "active" => "Đang sử dụng",
                            "passed" => "Đã qua",
                            "maintenance" => "Đang bảo trì",
                            _ => "Chưa đặt"
                        };
                        var cssClass = string.IsNullOrEmpty(status) ? "available" : status;

                        <td class="@cssClass"
                            data-date="@day.ToString("yyyy-MM-dd")"
                            data-hour="@hour"
                            data-room="@Model.SelectedRoom"
                            title="@(status == "maintenance" ? "Phòng đang bảo trì" : "")">
                            @statusText
                        </td>
                    }
                </tr>
            }
        </tbody>

    </table>

    <div class="text-center mt-4">
        <a asp-page="/Rooms/Book" asp-route-room="@Model.SelectedRoom" class="btn btn-warning me-2">🚀 Đặt Lịch Ngay</a>
        <a href="javascript:history.back()" class="btn btn-primary">🔙 Quay lại</a>
    </div>
</div>

@section Scripts {
    <script>
        const room = "@Model.SelectedRoom";

        // Chuyển phòng
        function changeRoom() {
            const selectedRoom = document.getElementById("roomSelect").value;
            window.location.href = '/Rooms/Lich-trong?SelectedRoom=' + encodeURIComponent(selectedRoom);
        }

        // Kết nối SignalR
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/bookingHub")
            .withAutomaticReconnect()
            .build();

        // Khi kết nối thành công
        connection.start()
            .then(() => {
                console.log("✅ Đã kết nối đến SignalR Hub");
            })
            .catch(err => {
                console.error("❌ Lỗi kết nối SignalR:", err);
            });

        // Khi nhận thời gian từ server
              connection.on("ReceiveTime", now => {
            const clock = document.getElementById("currentTime");
            if (clock) {
                // Giữ nguyên chuỗi từ server (đã theo định dạng 24h)
                clock.innerText = now;
            }
            updatePassedStatus(); // Cập nhật trạng thái dựa theo giờ hiện tại
        });


        // Hàm chuẩn hóa trạng thái
        function normalizeStatus(status) {
            if (status === "cancelled") return "available";
            if (status === "completed") return "passed";
            return status;
        }

        // Văn bản hiển thị theo trạng thái
        function statusText(status) {
            switch (status) {
                case "pending": return "Chờ duyệt";
                case "booked": return "Đã đặt";
                case "active": return "Đang sử dụng";
                case "passed": return "Đã qua";
                case "maintenance": return "Đang bảo trì";
                default: return "Chưa đặt";
            }
        }

        // Cập nhật trạng thái ô
        function updateCell(dateStr, hour, status, duration = 1) {
            for (let i = 0; i < duration; i++) {
                const cell = document.querySelector(`[data-date='${dateStr}'][data-hour='${hour + i}']`);
                if (!cell) continue;

                cell.className = status;
                cell.textContent = statusText(status);

                if (status === "available") {
                    cell.title = "Giờ này đang trống";
                    cell.style.cursor = "default";
                } else if (status === "maintenance") {
                    cell.title = "Phòng đang bảo trì";
                    cell.style.cursor = "not-allowed";
                } else {
                    cell.title = "";
                    cell.style.cursor = "default";
                }
            }
        }

              function updatePassedStatus() {
            const now = new Date();
            const todayStr = now.toISOString().slice(0, 10);
            const nowMinutes = now.getHours() * 60 + now.getMinutes();

            document.querySelectorAll("td[data-date][data-hour]").forEach(cell => {
                const dateStr = cell.getAttribute("data-date");
                const hour = parseInt(cell.getAttribute("data-hour"));
                const cellMinutes = hour * 60;

                let status = cell.className.trim().toLowerCase();
                if (status === "chua-dat") status = "available";

                if (dateStr !== todayStr) return;

                if (nowMinutes >= cellMinutes) {
                    // 👉 Nếu giờ hiện tại >= giờ trong ô → coi như Đã qua
                    if (!["active", "maintenance"].includes(status)) {
                        cell.className = "passed";
                        cell.textContent = "Đã qua";
                        cell.title = "Khung giờ đã qua";
                        cell.style.cursor = "default";
                    }
                } else if (nowMinutes >= cellMinutes && nowMinutes < cellMinutes + 60 && status === "booked") {
                    // 🔶 Nếu đang trong giờ booked thì active
                    cell.className = "active";
                    cell.textContent = "Đang sử dụng";
                    cell.title = "Phòng đang sử dụng";
                    cell.style.cursor = "default";
                }
            });
        }


        // Ghi nhớ trạng thái ban đầu các ô
        const originalStatuses = {};
        document.querySelectorAll("td[data-date][data-hour]").forEach(cell => {
            const dateStr = cell.getAttribute("data-date");
            const hour = cell.getAttribute("data-hour");
            originalStatuses[`${dateStr}_${hour}`] = cell.className || "available";
        });

        // Khi booking mới được tạo
        connection.on("BookingCreated", booking => {
            if (booking.roomId !== room) return;

            const hour = parseInt(booking.startTime.split(':')[0]);
            updateCell(booking.rentalDate, hour, normalizeStatus(booking.status), booking.rentalDuration);
        });

        // Khi trạng thái đơn thay đổi
        connection.on("BookingStatusChanged", (id, roomId, date, startHour, duration, newStatus) => {
            if (roomId !== room) return;
            updateCell(date.split('T')[0], startHour, normalizeStatus(newStatus), duration);
        });
                // Khi đơn bị xóa
        connection.on("BookingDeleted", (id, roomId, date, startHour, duration) => {
            if (roomId !== room) return; // Chỉ cập nhật nếu là đúng phòng đang xem
            updateCell(date.split('T')[0], startHour, "available", duration);
        });

        // Khi phòng được cập nhật bảo trì
        connection.on("MaintenanceUpdated", maintenanceRooms => {
            document.querySelectorAll("td[data-date][data-hour]").forEach(cell => {
                const cellRoom = cell.getAttribute("data-room");
                const dateStr = cell.getAttribute("data-date");
                const hour = cell.getAttribute("data-hour");
                const key = `${dateStr}_${hour}`;

                if (maintenanceRooms.includes(cellRoom)) {
                    cell.className = "maintenance";
                    cell.textContent = "Đang bảo trì";
                    cell.title = "Phòng đang bảo trì";
                    cell.style.cursor = "not-allowed";
                } else {
                    const original = originalStatuses[key] || "available";
                    cell.className = original;
                    cell.textContent = statusText(original);
                    cell.title = "";
                    cell.style.cursor = "default";
                }
            });
        });

        // Lặp lại kiểm tra thời gian mỗi phút đề phòng Hub lỗi
        setInterval(updatePassedStatus, 60000);

        // Khi DOM tải xong
        document.addEventListener("DOMContentLoaded", () => {
            updatePassedStatus();
        });
    </script>
}
