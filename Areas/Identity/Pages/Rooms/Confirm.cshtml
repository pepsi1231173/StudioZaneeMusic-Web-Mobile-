@page
@model DuAnBai3.Pages.ConfirmModel
@{
    ViewData["Title"] = "Xác nhận đặt phòng";
}

<h2>Xác nhận đặt phòng</h2>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-danger">@Model.Message</div>
}

<form method="get" asp-page="/Confirm">
    <div class="mb-3">
        <label class="form-label">Phòng:</label>
        <input asp-for="RoomId" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Tên khách hàng:</label>
        <input asp-for="CustomerName" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Số điện thoại:</label>
        <input asp-for="CustomerPhone" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Email:</label>
        <input asp-for="CustomerEmail" class="form-control" type="email" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Ngày thuê:</label>
        <input asp-for="RentalDate" class="form-control" type="date" required min="@DateTime.Today.ToString("yyyy-MM-dd")" />
    </div>

    <div class="mb-3">
        <label class="form-label">Giờ bắt đầu:</label>
        <input asp-for="StartTime" class="form-control" type="time" required min="08:00" max="22:00" />
    </div>

    <div class="mb-3">
        <label class="form-label">Số giờ thuê:</label>
        <input asp-for="RentalDuration" class="form-control" type="number" min="1" max="14" required />
        <small class="text-muted">Số giờ thuê tối đa 14h (đặt trong khoảng 8h - 22h)</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Số khách:</label>
        <input asp-for="GuestCount" class="form-control" type="number" min="1" required />
    </div>

    <button type="submit" class="btn btn-primary">Xác nhận đặt phòng</button>
</form>
