@page "/Rooms/Book/{room?}"
@model DuAnBai3.Areas.Identity.Pages.Rooms.BookModel
@{
    ViewData["Title"] = "Thuê Phòng Tập";
    Layout = "~/Areas/Identity/Pages/Shared/_Layout.cshtml";


    // Lấy room từ route hoặc từ model, mặc định là A
    string selectedRoom = (Model.Booking.RoomId ?? (string)RouteData.Values["room"] ?? "A").ToUpper();

    // Gán lại RoomId nếu chưa có
    if (string.IsNullOrEmpty(Model.Booking.RoomId))
    {
        Model.Booking.RoomId = selectedRoom;
    }

    // Nếu route có room thì disable
    bool disableRoomSelect = !string.IsNullOrEmpty((string)RouteData.Values["room"]);
}

<style>
    body {
        background: url('/images/room_rental.gif') no-repeat center center fixed;
        background-size: cover;
        color: papayawhip;
        font-family: 'Poppins', sans-serif;
        min-height: 100vh;
    }

    .container {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.05));
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
        max-width: 900px;
        backdrop-filter: blur(12px);
        margin: 50px auto;
        text-align: center;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .title {
        font-size: 36px;
        font-family: 'Lobster', cursive;
        margin-bottom: 20px;
    }

    /* Toast container ở trên cùng chính giữa màn hình */
    #toast-container-top {
        position: fixed;
        top: 15px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1080;
        max-width: 650px;
        width: auto;
    }

    .toast {
        min-width: 400px; /* toast to hơn */
        font-size: 1.2rem; /* chữ to hơn */
        font-weight: 600;
        opacity: 0.95;
        box-shadow: 0 0 15px rgba(0,0,0,0.3);
        border-radius: 8px;
    }
</style>

<div id="toast-container-top"></div>

<div class="container">
    <h2 class="title">🎸 Đặt Lịch Thuê Phòng Tập</h2>
    <p>Ngày giờ hiện tại: <span id="timeDisplay">@DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")</span></p>

    <form method="post">
        <div class="row">
            <div class="col-md-6 mb-3 text-start">
                <label asp-for="Booking.CustomerName" class="form-label">Họ và tên:</label>
                <input asp-for="Booking.CustomerName" class="form-control" placeholder="Nhập họ và tên" />
                <span asp-validation-for="Booking.CustomerName" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3 text-start">
                <label asp-for="Booking.CustomerPhone" class="form-label">Số điện thoại:</label>
                <input asp-for="Booking.CustomerPhone" class="form-control" placeholder="Nhập số điện thoại" />
                <span asp-validation-for="Booking.CustomerPhone" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3 text-start">
                <label asp-for="Booking.CustomerEmail" class="form-label">Email:</label>
                <input asp-for="Booking.CustomerEmail" class="form-control" placeholder="Nhập email" />
                <span asp-validation-for="Booking.CustomerEmail" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3 text-start">
                <label asp-for="Booking.RentalDate" class="form-label">Ngày thuê:</label>
                <input asp-for="Booking.RentalDate" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="Booking.RentalDate" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="mb-3">
                <label class="form-label">Giờ bắt đầu (08:00 - 22:00):</label>
                <select asp-for="Booking.StartHour" class="form-select" required>
                    @for (int h = 8; h <= 22; h++)
                    {
                        <option value="@h">@h.ToString("D2"):00</option>
                    }
                </select>
                <span class="text-danger" asp-validation-for="Booking.StartHour"></span>
            </div>

            <div class="col-md-4 mb-3 text-start">
                <label asp-for="Booking.RentalDuration" class="form-label">Thời gian thuê (giờ):</label>
                <input asp-for="Booking.RentalDuration" type="number" min="1" max="14" class="form-control" />
                <span asp-validation-for="Booking.RentalDuration" class="text-danger"></span>
            </div>

            <div class="col-md-4 mb-3 text-start">
                <label asp-for="Booking.RoomId" class="form-label">Tên phòng:</label>
                <select asp-for="Booking.RoomId" class="form-select" disabled="@(disableRoomSelect ? "disabled" : null)">
                    <option value="A" selected="@(selectedRoom == "A" ? "selected" : null)">A</option>
                    <option value="B" selected="@(selectedRoom == "B" ? "selected" : null)">B</option>
                    <option value="C" selected="@(selectedRoom == "C" ? "selected" : null)">C</option>
                </select>
                @if (disableRoomSelect)
                {
                    <input type="hidden" asp-for="Booking.RoomId" />
                }
                <span asp-validation-for="Booking.RoomId" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3 text-start">
            <label id="guestLimitLabel" asp-for="Booking.GuestCount" class="form-label">
                Số lượng khách (tối đa @(selectedRoom == "B" ? 20 : selectedRoom == "C" ? 30 : 10), thêm 30k/khách nếu vượt):
            </label>

            <input asp-for="Booking.GuestCount" type="number" min="1" class="form-control" />
            <span asp-validation-for="Booking.GuestCount" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-page="/Rooms/Lich-trong" class="btn btn-info">🗓️ Xem Lịch Trống</a>
            <button type="submit" class="btn btn-warning">🚀 Đặt Lịch Ngay</button>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success mt-3">@Model.SuccessMessage</div>
    }

    <div class="text-danger mt-3">
        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@e.ErrorMessage</p>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        let maintenanceRooms = [];

        // Hàm hiển thị toast
        function showToast(containerId, message, bgClass = "bg-info", delay = 4000) {
            const container = document.getElementById(containerId) || document.body;
            const toast = document.createElement('div');
            toast.className = `toast align-items-center text-white ${bgClass} border-0 show mt-2`;
            toast.style.minWidth = "400px";
            toast.style.fontSize = "1.2rem";
            toast.style.fontWeight = "600";
            toast.style.opacity = "0.95";
            toast.style.boxShadow = "0 0 15px rgba(0,0,0,0.3)";
            toast.style.borderRadius = "8px";
            toast.role = "alert";

            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">${message}</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>`;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), delay);
        }

        // Gọi danh sách phòng bảo trì ban đầu
        async function fetchMaintenanceRooms() {
            const res = await fetch('/Admin/Booking/GetMaintenance');
            if (res.ok) {
                maintenanceRooms = await res.json();
                disableMaintenanceRooms();
            }
        }

        // Vô hiệu hóa các phòng đang bảo trì trong dropdown
        function disableMaintenanceRooms() {
            const roomSelect = document.querySelector('select[name="Booking.RoomId"]');
            Array.from(roomSelect.options).forEach(opt => {
                if (maintenanceRooms.includes(opt.value)) {
                    opt.disabled = true;
                    if (!opt.text.includes("(Bảo trì)")) {
                        opt.text += " (Bảo trì)";
                    }
                } else {
                    opt.disabled = false;
                    opt.text = opt.text.replace(" (Bảo trì)", "");
                }
            });
        }

        // Tạo kết nối tới hub
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/bookingHub")
            .build();

        connection.start()
            .then(() => console.log("✅ Connected to bookingHub"))
            .catch(err => console.error(err.toString()));

        // Nhận thời gian hiện tại
        connection.on("ReceiveTime", (now) => {
            document.getElementById("timeDisplay").innerText = now;
        });

        // Nhận danh sách phòng bảo trì mới
        connection.on("MaintenanceUpdated", rooms => {
            maintenanceRooms = rooms;
            showToast("toast-container-top", `⚠️ Các phòng đang bảo trì: ${rooms.join(', ')}`, "bg-warning");
            disableMaintenanceRooms();
        });

        // Cập nhật số khách tối đa theo loại phòng
        document.querySelector('select[name="Booking.RoomId"]').addEventListener('change', function () {
            const room = this.value.trim().toUpperCase();
            let max = 10;
            if (room === 'B') max = 20;
            else if (room === 'C') max = 30;

            document.getElementById('guestLimitLabel').innerText =
                `Số lượng khách (tối đa ${max}, thêm 30k/khách nếu vượt):`;
        });

        // --- PHẦN KIỂM TRA ĐẶT TRÙNG GIỜ ---

        async function checkDuplicateBooking(roomId, rentalDate, startHour, duration) {
            // Gọi API backend trả về true nếu có trùng, false nếu không
            try {
                const response = await fetch('/Admin/Booking/CheckDuplicate', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ roomId, rentalDate, startHour, duration })
                });
                if (response.ok) {
                    const result = await response.json();
                    return result.isDuplicate; // true hoặc false
                } else {
                    console.error("Lỗi khi gọi API kiểm tra trùng");
                    return true; // an toàn hơn là cấm đặt
                }
            } catch (error) {
                console.error("Lỗi fetch API kiểm tra trùng:", error);
                return true;
            }
        }

        // Bắt sự kiện submit form
        document.querySelector('form').addEventListener('submit', async function (e) {
            const room = document.querySelector('select[name="Booking.RoomId"]').value;
            const rentalDate = document.querySelector('input[name="Booking.RentalDate"]').value;
            const startHour = parseInt(document.querySelector('select[name="Booking.StartHour"]').value);
            const duration = parseInt(document.querySelector('input[name="Booking.RentalDuration"]').value);

            // Kiểm tra phòng bảo trì
            if (maintenanceRooms.includes(room)) {
                e.preventDefault();
                showToast("toast-container-top", `❌ Phòng ${room} đang bảo trì, vui lòng chọn phòng khác.`, "bg-danger");
                return;
            }

            // Kiểm tra trùng giờ
            const isDuplicate = await checkDuplicateBooking(room, rentalDate, startHour, duration);
            if (isDuplicate) {
                e.preventDefault();
                showToast("toast-container-top", `❌ Phòng ${room} đã có người đặt trùng giờ. Vui lòng chọn giờ khác.`, "bg-danger");
                return;
            }

            // Nếu không có lỗi thì submit form tiếp tục
        });

        // Tải dữ liệu phòng bảo trì khi load trang
        fetchMaintenanceRooms();
    </script>
}

