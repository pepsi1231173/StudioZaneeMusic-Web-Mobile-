@page
@model DuAnBai3.Areas.Identity.Pages.Rooms.IndexModel
@{
    ViewData["Title"] = "Danh sách phòng";
    Layout = "~/Areas/Identity/Pages/Shared/_Layout.cshtml";
}

<!-- ================ CSS & LIBS ================ -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />

<style>
    body {
        background: url('/images/room_rental.gif') no-repeat fixed center/cover;
        color: #fff;
    }

    .container {
        max-width: 1400px;
        margin: 60px auto 80px;
        padding: 40px;
        background: rgba(45,33,13,.8);
        border-radius: 12px;
        box-shadow: 0 0 25px rgba(255,255,255,.4);
    }

    .table th, .table td {
        vertical-align: middle !important;
        text-align: center;
        color: #000;
        font-size: 1.2rem;
        padding: 1.8rem 1.2rem
    }

        .table td ul {
            padding-left: 1.4rem;
            text-align: left;
            font-size: 1rem
        }

    .btn-dat-ngay {
        background: linear-gradient(135deg,#ff9f00,#ff3c00);
        color: #fff;
        font-weight: 700;
        border: none;
        font-size: 1.1rem;
        padding: 14px 22px;
        border-radius: 14px;
        transition: .3s
    }

        .btn-dat-ngay:hover {
            background: linear-gradient(135deg,#ff6a00,#ff0000);
            transform: scale(1.1)
        }

    @@keyframes gentleGlow {
        0%, 100% {
            text-shadow: 0 0 10px #fff,0 0 18px currentColor,0 0 28px currentColor
        }

        50% {
            text-shadow: 0 0 6px #fff,0 0 9px currentColor,0 0 15px currentColor
        }
    }

    .room-badge {
        display: inline-block;
        padding: 8px 22px;
        border-radius: 16px;
        font-weight: 700;
        font-size: 1rem;
        animation: gentleGlow 2s infinite
    }

    .room-standard {
        background: #2e2e2e;
        color: #d3d3d3
    }

    .room-vip {
        background: #003366;
        color: #89e4ff
    }

    .room-svip {
        background: #3b0000;
        color: #ff7b7b
    }

    .room-maintenance, .room-maintenance td {
        background: #6c757d !important;
        color: #fff !important;
    }

    img {
        max-width: 240px !important;
        max-height: 180px !important;
        object-fit: cover;
        border-radius: 16px;
        margin-bottom: 15px
    }

    .navbar-brand {
        font-family: 'Lobster', cursive;
        font-size: 2rem;
        font-weight: 900;
        text-transform: uppercase;
        color: #ffdd00;
        text-shadow: 0 0 5px #fff, 0 0 10px #ffdd00, 0 0 20px #ffcc00, 0 0 40px #ffbb00, 0 0 60px #ffaa00, 0 0 80px #ff9900;
        display: flex;
        align-items: center;
    }
    @@keyframes glowPulse {
        0%

    {
        text-shadow: 0 0 3px #fff, 0 0 6px #ffdd00, 0 0 10px #ffcc00;
    }

    100% {
        text-shadow: 0 0 10px #fff, 0 0 20px #ffdd00, 0 0 30px #ffcc00;
    }

    }
</style>

<div class="container" data-aos="zoom-in">
    <h2 class="text-center text-warning mb-4">Danh sách phòng</h2>

    <table class="table table-bordered table-hover">
        <thead>
            <tr><th>Tên phòng</th><th>Giá thuê</th><th>Đặt lịch</th></tr>
        </thead>
        <tbody>
            @foreach (var room in Model.Rooms)
            {
                var isMt = Model.MaintenanceRooms.Contains(room.Name);
                <tr data-room="@room.Name" class="@(isMt ? "room-maintenance" : "")">
                    <td class="fw-bold text-center align-middle">
                        @room.Name
                        @if (isMt)
                        {
                            <div class="text-danger">(Đang bảo trì)</div>
                        }
                    </td>
                    <td class="align-middle">
                        <div class="room-badge
                             @(room.Type.ToLower() == "standard" ? "room-standard" :
                               room.Type.ToLower() == "vip" ? "room-vip" :
                               "room-svip")">
                            @room.Type
                        </div>
                        <ul class="list-unstyled mb-0 price-details">
                            <li>📅 T2–T6: <strong>@($"{room.WeekdayPrice:N0}") VNĐ/giờ</strong></li>
                            <li>🌟 T7, CN, Lễ: <strong>@($"{room.WeekendPrice:N0}") VNĐ/giờ</strong></li>
                            <li>🔥 Golden Hours (14‑17h): <strong>@($"{room.GoldenHourPrice:N0}") VNĐ/giờ</strong></li>
                            <li>👥 Tối đa @room.MaxPeople người</li>
                        </ul>
                    </td>
                    <td class="text-center align-middle">
                        @if (isMt)
                        {
                            <button class="btn btn-secondary btn-maintenance" disabled>🔧 Bảo trì</button>
                        }
                        else
                        {
                            <a asp-page="/Rooms/Book" asp-route-room="@room.Name" class="btn btn-dat-ngay">Đặt ngay</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ============== JS & SignalR ============== -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder().withUrl("/bookingHub").build();

        connection.on("MaintenanceUpdated", rooms => updateMaintenanceUI(rooms));

        connection.start()
            .then(() => fetch("/Admin/Booking/GetMaintenance")
                         .then(r => r.json())
                         .then(updateMaintenanceUI))
            .catch(console.error);

        function updateMaintenanceUI(rooms) {
            document.querySelectorAll("tr[data-room]").forEach(tr => {
                tr.classList.remove("room-maintenance");

                const bookBtn = tr.querySelector(".btn-dat-ngay");
                if (bookBtn) {
                    bookBtn.style.display = "inline-block"; // ✅ hiện lại nếu từng bị ẩn
                }

                tr.querySelector(".btn-maintenance")?.remove();
                tr.querySelector("td:first-child .text-danger")?.remove();
            });

            rooms.forEach(name => {
                const row = document.querySelector(`tr[data-room="${name}"]`);
                if (!row) return;

                row.classList.add("room-maintenance");

                const bookBtn = row.querySelector(".btn-dat-ngay");
                if (bookBtn) bookBtn.style.display = "none"; // ẩn nút đặt

                const tdAction = row.querySelector("td:last-child");
                if (tdAction && !row.querySelector(".btn-maintenance")) {
                    tdAction.insertAdjacentHTML("beforeend",
                        `<button class="btn btn-secondary btn-maintenance" disabled>🔧 Bảo trì</button>`);
                }

                if (!row.querySelector("td:first-child .text-danger")) {
                    row.querySelector("td:first-child")
                        .insertAdjacentHTML("beforeend", `<div class="text-danger">(Đang bảo trì)</div>`);
                }
            });
        }

        AOS.init({ duration: 2000 });
    </script>
}
