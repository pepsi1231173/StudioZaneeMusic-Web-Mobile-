@page
@model DuAnBai3.Pages.ServiceHistoryModel
@{
    ViewData["Title"] = "Lịch Sử Dịch Vụ";
    Layout = "~/Areas/Identity/Pages/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

<style>
    body {
        background: url('/images/day_background.gif') no-repeat center center fixed;
        background-size: cover;
        color: white;
        font-family: Arial, sans-serif;
    }

    .container {
        background: rgba(32, 140, 154, 0.8);
        border-radius: 10px;
        padding: 30px;
        max-width: 900px;
        width: 90%;
        margin: 40px auto;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);
    }

    .title {
        font-family: 'Lobster', cursive;
        font-weight: bold;
        letter-spacing: 2px;
        color: #FFD700;
        text-shadow: 3px 3px 8px rgba(17, 17, 17, 0.7);
        font-size: 35px;
        text-align: center;
    }

    table {
        width: 100%;
        margin-top: 20px;
        margin-bottom: 30px;
        background: white;
        border-radius: 8px;
        overflow: hidden;
        color: black;
    }

    th, td {
        padding: 12px;
        border-bottom: 1px solid #ddd;
        text-align: center;
    }

    th {
        background: #ffcc00;
        color: black;
    }

    tr:nth-child(even) {
        background: #f2f2f2;
    }

    .btn {
        background: linear-gradient(45deg, #ff0066, #ffcc00);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 8px 14px;
        font-size: 1rem;
        text-decoration: none;
        transition: 0.3s;
        display: inline-block;
    }

        .btn:hover {
            background: linear-gradient(45deg, #ffcc00, #ff0066);
            transform: scale(1.05);
        }
</style>

<div class="container">
    <h2 class="title">📜 Lịch Sử Dịch Vụ 📜</h2>
    <!-- Thuê Phòng -->
    <h3>🏠 Thuê Phòng</h3>
    <table border="1" cellpadding="5" cellspacing="0" style="border-collapse: collapse; width:100%;">
        <tr>
            <th>Phòng</th>
            <th>Ngày đặt</th>
            <th>Giờ bắt đầu</th>
            <th>Giờ kết thúc</th>
            <th>Giá (VNĐ)</th>
            <th>Trạng thái</th>
            <th>Hóa đơn</th>
        </tr>
        @if (Model.BookingHistory.Any())
        {
            @foreach (var item in Model.BookingHistory)
            {
                var (statusText, statusColor) = item.Status.ToLower() switch
                {
                    "pending" => ("Chờ duyệt", "orange"),
                    "active" => ("Đang sử dụng", "green"),
                    "completed" => ("Hoàn tất", "gray"),
                    "cancelled" => ("Đã hủy", "red"),
                    _ => ("Không xác định", "black")
                };

                <tr>
                    <td>@item.RoomId</td>
                    <td>@item.RentalDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.RentalDate.Add(item.StartTime).ToString("HH:mm")</td>
                    <td>@item.RentalDate.Add(item.EndTime).ToString("HH:mm")</td>
                    <td>@item.Price.ToString("#,0").Replace(",", ".")</td>
                    <td style="color:@statusColor; font-weight:bold;">@statusText</td>
                    <td><a href="/Identity/Rooms/Invoice?bookingid=@item.Id" class="btn">📄 Xem Hóa Đơn</a></td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="6">Không có lịch sử thuê phòng.</td></tr>
        }
    </table>

    <!-- Thuê Nhạc Cụ -->
    <h3>🎸 Thuê Nhạc Cụ</h3>
    <table border="1" cellpadding="5" cellspacing="0" style="border-collapse: collapse; width:100%;">
        <thead>
            <tr>
                <th>Nhạc cụ</th>
                <th>Ngày thuê</th>
                <th>Giá</th>
                <th>Trạng thái</th>
                <th>Hóa đơn</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.InstrumentHistory.Any())
            {
                <tr>
                    <td colspan="5" style="text-align:center;">Không có lịch sử thuê nhạc cụ.</td>
                </tr>
            }
            else
            {
                @foreach (var rental in Model.InstrumentHistory)
                {
                    var (statusText, statusColor) = rental.Status.ToLower() switch
                    {
                        "pending" => ("Chờ duyệt", "orange"),
                        "active" => ("Đang thuê", "green"),
                        "completed" => ("Hoàn tất", "blue"),
                        "cancelled" => ("Đã hủy", "red"),
                        _ => ("Không xác định", "gray")
                    };

                    <tr>
                        <td>
                            <div style="display:grid; grid-template-columns: repeat(2, 1fr); gap:12px;">
                                @for (int i = 0; i < rental.InstrumentImage.Split(',', StringSplitOptions.RemoveEmptyEntries).Length; i++)
                                {
                                    var images = rental.InstrumentImage.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                    var names = rental.InstrumentName.Split(',', StringSplitOptions.None);

                                    <div class="text-center">
                                        <img src="@images[i]" style="width:120px; height:120px; object-fit:cover; border:1px solid #ccc; border-radius:5px;" />
                                        <div style="font-size:0.9rem; margin-top:4px; word-wrap:break-word;">
                                            @if (i < names.Length)
                                            {
                                                @names[i].Trim()
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </td>
                        <td>@rental.RentalDate.ToString("dd/MM/yyyy")</td>
                        <td>@rental.Price.ToString("#,0").Replace(",", ".") VNĐ</td>
                        <td><span style="color:@statusColor">@statusText</span></td>
                        <td>
                            <a href="@Url.Page("/Instruments/Invoice", new { area = "Identity", rental_id = rental.Id })"
                               class="btn btn-primary btn-sm w-120">
                                📄 Xem hóa đơn
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>


    <!-- Thu Âm -->
    <h3>🎤 Dịch Vụ Thu Âm</h3>
    <table border="1" cellpadding="5" cellspacing="0" style="border-collapse: collapse; width:100%;">
        <thead>
            <tr>
                <th>Gói thu âm</th>
                <th>Ngày thu</th>
                <th>Giờ bắt đầu</th>
                <th>Giờ kết thúc</th>
                <th>Giá</th>
                <th>Trạng thái</th>
                <th>Hóa đơn</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.RecordingHistory.Any())
            {
                <tr>
                    <td colspan="7" style="text-align:center;">Không có lịch sử thu âm.</td>
                </tr>
            }
            else
            {
                @foreach (var booking in Model.RecordingHistory)
                {
                    // Map trạng thái tiếng Anh sang tiếng Việt và màu sắc
                    var statusNormalized = booking.Status?.Trim().ToLower(); // chuẩn hóa

                    var (statusText, statusColor) = statusNormalized switch
                    {
                        "canceled" => ("Đã hủy", "red"),
                        "confirmed" => ("Đã duyệt", "green"),
                        "pending" => ("Chờ duyệt", "orange"),
                        _ => ("Không xác định", "gray")
                    };

                    <tr>
                        <td>@booking.RecordingPackage</td>
                        <td>@booking.SessionDate.ToString("dd/MM/yyyy")</td>
                        <td>@booking.StartTimeStr</td>
                        <td>@booking.EndTimeStr</td>
                        <td>@booking.Price.ToString("#,0").Replace(",", ".") VNĐ</td>
                        <td><span style="color:@statusColor; font-weight:bold;">@statusText</span></td>
                        <td>
                            <a href="/Identity/Recording/InvoiceRecording/@booking.Id"
                               class="btn btn-primary btn-sm w-100">
                                📄 Xem hóa đơn
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    @functions {
        // Helper chuyển TimeSpan thành HH:mm
        public string FormatTime(TimeSpan time)
        {
            return time.ToString(@"hh\:mm");
        }
    }



    <!-- Làm Nhạc -->
    <h3>🎼 Dịch Vụ Làm Nhạc</h3>
    <table border="1" cellpadding="5" cellspacing="0" style="border-collapse: collapse; width:100%;">
        <thead>
            <tr>
                <th>Ngày yêu cầu</th>
                <th>Thể loại nhạc</th>
                <th>Mô tả</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.MusicRequestHistory.Any())
            {
                <tr>
                    <td colspan="4" style="text-align:center;">Không có lịch sử làm nhạc.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.MusicRequestHistory)
                {
                    // Chuẩn hóa trạng thái
                    var statusNormalized = item.Status?.Trim().ToLower();

                    var (statusText, statusColor) = statusNormalized switch
                    {
                        "pending" => ("Đang chờ", "orange"),
                        "confirmed" => ("Đã duyệt", "green"), // đổi từ approved → confirmed
                        "canceled" => ("Từ chối", "red"),     // đổi rejected → canceled cho khớp với admin
                        _ => ("Không xác định", "gray")
                    };


                    <tr>
                        <td>@item.RequestDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.MusicGenre</td>
                        <td>@item.MusicDescription</td>
                        <td><span style="color:@statusColor; font-weight:bold;">@statusText</span></td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <a href="/Identity/Homepage" class="btn btn-primary mt-3">Quay lại trang chủ</a>

