@page
@model DuAnBai3.Areas.Identity.Pages.Recording.RecordingModel
@{
    ViewData["Title"] = "Dịch Vụ Thu Âm & Làm Nhạc";
    Layout = "~/Areas/Identity/Pages/Shared/_Layout.cshtml";
    // Lấy ngày hiện tại theo định dạng yyyy-MM-dd
    var today = DateTime.Now.ToString("yyyy-MM-dd");
}

@section Styles {
    <style>
        body {
            background: url('/images/night_background.gif') no-repeat center center fixed;
            background-size: cover;
            color: white;
            font-family: 'Poppins', sans-serif;
        }

        .container-form {
            background: rgba(255, 255, 255, 0.12);
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.4);
            text-align: center;
            max-width: 600px;
            width: 90%;
            margin: 40px auto;
            backdrop-filter: blur(8px);
            color: white;
        }

        .title {
            font-size: 40px;
            font-weight: bold;
            color: #f1c40f;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            margin-bottom: 20px;
        }

        .service-option {
            display: flex;
            align-items: center;
            padding: 14px;
            border-radius: 12px;
            font-size: 18px;
            font-weight: bold;
            transition: all 0.3s;
            cursor: pointer;
            text-align: left;
            width: 100%;
            margin-bottom: 12px;
            border: 2px solid transparent;
            background: linear-gradient(45deg, #0f3460, #1a1a2e);
            color: white;
        }

            .service-option:hover {
                border-color: #f1c40f;
                transform: scale(1.05);
            }

            .service-option input {
                margin-right: 10px;
            }

        .input-group {
            background: rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            padding: 12px;
            display: flex;
            align-items: center;
            margin-bottom: 15px;
            box-shadow: 0 3px 6px rgba(0,0,0,0.2);
            transition: all 0.3s;
            border: 2px solid transparent;
        }

            .input-group:hover {
                background: rgba(255,255,255,0.4);
            }

            .input-group:focus-within {
                border: 2px solid #ffa500;
            }

            .input-group input {
                border: none;
                outline: none;
                flex: 1;
                padding: 12px;
                font-size: 16px;
                border-radius: 8px;
                background: transparent;
                color: white;
            }

                .input-group input::placeholder {
                    color: rgba(255, 255, 255, 0.7);
                }

            .input-group i {
                padding: 12px;
                color: #f1c40f;
                font-size: 18px;
            }

        .form button {
            background: linear-gradient(45deg, #ff6b6b, #f1c40f);
            color: white;
            border: none;
            border-radius: 25px;
            padding: 10px 18px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            width: auto;
            min-width: 180px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        }

            .form button:hover {
                background: linear-gradient(45deg, #f1c40f, #ff6b6b);
                transform: scale(1.05);
            }

        .header-space {
            height: 30px;
        }
    </style>
}

<div class="header-space"></div>

<div class="container-form">
    <h2 class="title">🎤 Dịch Vụ Thu Âm Chuyên Nghiệp</h2>
    <form method="post">
        <label class="service-option">
            <input asp-for="Input.RecordingPackage" type="radio" value="Thu âm thô" required /> 🎤 Thu âm thô - <strong>200.000VNĐ</strong>
        </label>
        <label class="service-option">
            <input asp-for="Input.RecordingPackage" type="radio" value="Thu âm chỉnh sửa" /> 🎧 Thu âm chỉnh sửa - <strong>400.000VNĐ</strong>
        </label>
        <label class="service-option">
            <input asp-for="Input.RecordingPackage" type="radio" value="Full chỉnh sửa & tư vấn kỹ thuật" /> 🎼 Full chỉnh sửa & tư vấn kỹ thuật - <strong>900.000VNĐ/h</strong>
        </label>

        <div class="row mt-3">
            <div class="col-md-6 mb-3 text-start">
                <label asp-for="Input.RecordingDate" class="form-label">Ngày thu:</label>
                <input asp-for="Input.RecordingDate" type="date" class="form-control" min="@today" value="@today" />
            </div>

            <div class="col-md-6 mb-3 text-start">
                <label class="form-label">Giờ bắt đầu (08:00 - 21:00):</label>
                <select asp-for="Input.RecordingStartHour" class="form-select" required>
                    @for (int h = 8; h <= 21; h++)
                    {
                        <option value="@h">@h.ToString("D2"):00</option>
                    }
                </select>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3 text-start">
                <label asp-for="Input.RecordingDuration" class="form-label">Thời lượng thu âm (giờ):</label>
                <input asp-for="Input.RecordingDuration" type="number" min="1" max="8" class="form-control" value="1" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3 text-start">
                <label asp-for="Input.CustomerName" class="form-label">Họ tên:</label>
                <input asp-for="Input.CustomerName" class="form-control" placeholder="Nhập họ và tên" />
            </div>
            <div class="col-md-6 mb-3 text-start">
                <label asp-for="Input.CustomerEmail" class="form-label">Email:</label>
                <input asp-for="Input.CustomerEmail" class="form-control" placeholder="Nhập email" />
            </div>
        </div>

        <div class="mb-3 text-start">
            <label asp-for="Input.CustomerPhone" class="form-label">Số điện thoại:</label>
            <input asp-for="Input.CustomerPhone" class="form-control" placeholder="Nhập số điện thoại" />
        </div>

        <button type="submit" class="btn btn-warning mt-2">🚀 Xác Nhận</button>
    </form>

    <div class="text-danger mt-3">
        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <p>@e.ErrorMessage</p>
        }
    </div>
</div>
