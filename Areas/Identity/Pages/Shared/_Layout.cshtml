@* File: /Areas/Identity/Pages/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Zanee's Music Studio</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Lobster&display=swap" rel="stylesheet" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }


        body {
            background: url('/images/background.jpg') no-repeat center center fixed;
            background-size: cover;
            color: white;
            text-align: center;
        }

        h1, p, .studio-title {
            font-family: 'Lobster', cursive;
        }

        h1 {
            letter-spacing: 2.2px;
            color: #FFD700;
            text-shadow: 3px 3px 8px rgba(112, 99, 25, 0.7);
            font-size: 45px;
        }

        nav.navbar, .navbar-brand, .navbar-nav .nav-link {
            font-family: 'Lobster', cursive !important;
        }

        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            background-color: transparent;
            padding: 0;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .navbar-brand {
            font-size: 2rem;
            font-weight: bold;
            text-transform: uppercase;
            color: white !important;
        }

        .container {
            max-width: 900px;
            margin-top: 80px;
            padding-bottom: 60px;
        }

        .navbar-nav .nav-link {
            font-size: 1.2rem;
            font-weight: 500;
            margin: 0 15px;
            color: white !important;
            transition: color 0.3s ease;
        }

            .navbar-nav .nav-link:hover {
                color: #ffcc70 !important;
                text-decoration: underline;
            }

        .studio-title {
            font-size: 2rem;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-weight: 900;
            color: #ffdd00;
            text-shadow: 0 0 5px #fff, 0 0 10px #ffdd00, 0 0 20px #ffcc00, 0 0 40px #ffbb00, 0 0 60px #ffaa00, 0 0 80px #ff9900;
            animation: glowPulse 2.5s ease-in-out infinite alternate;
        }

        @@keyframes glowPulse {
            0% {
                text-shadow: 0 0 3px #fff, 0 0 6px #ffdd00, 0 0 10px #ffcc00;
            }

            100% {
                text-shadow: 0 0 10px #fff, 0 0 20px #ffdd00, 0 0 30px #ffcc00;
            }
        }

        .fade-out {
            opacity: 1;
            transition: opacity 0.5s ease-in-out;
        }

            .fade-out.active {
                opacity: 0;
            }

        .footer,
        .footer-container,
        .footer-flex,
        .container.footer-flex {
            background: transparent !important;
            box-shadow: none !important;
            backdrop-filter: none !important;
            opacity: 1 !important;
            border: none !important; /* xóa viền */
            outline: none !important; /* xóa outline nếu có */
        }


        .footer-flex {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 65px;
            max-width: 1100px;
            width: 100%;
        }

        .link-wrapper {
            flex: 1 1 28%;
            color: #ddd;
            font-family: 'Lobster', cursive;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

            .link-wrapper h4 {
                color: #FFD700;
                margin-bottom: 12px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1.3px;
                position: relative;
            }

                .link-wrapper h4::after {
                    content: "";
                    position: absolute;
                    left: 0;
                    bottom: -4px;
                    width: 100%;
                    height: 2px;
                    background-color: #FFD700;
                }

            .link-wrapper ul {
                list-style: none;
                padding-left: 0;
                margin-left: 0;
                font-size: 0.95rem;
                line-height: 1.4;
                width: 100%;
            }

                .link-wrapper ul li {
                    display: flex;
                    align-items: center;
                    margin-bottom: 6px;
                }

                    /* Hiệu ứng icon 🎵 nhấp nháy nhẹ ở LIÊN KẾT NHANH */
                    .link-wrapper ul li::before {
                        content: "🎵";
                        color: #ffcc00;
                        font-size: 1rem;
                        margin-right: 6px;
                        display: inline-block;
                        animation: pulseIcon 2.5s infinite;
                    }

        @@keyframes pulseIcon {
            0%, 100% {
                opacity: 1;
                color: #ffcc00;
                transform: scale(1);
            }

            50% {
                opacity: 0.6;
                color: #ffd633;
                transform: scale(1.2);
            }
        }

        /* Hiệu ứng tiêu đề cột footer (h4) nhẹ rung và đổi màu */
        .link-wrapper h4 {
            position: relative;
            display: inline-block;
            animation: flickerText 3s infinite ease-in-out;
            cursor: default;
            color: #FFD700;
        }

        @@keyframes flickerText {
            0%, 100% {
                text-shadow: 0 0 6px #ffd633;
                color: #FFD700;
            }

            50% {
                text-shadow: 0 0 20px #fff;
                color: #fff8b0;
            }
        }

        /* Hiệu ứng icon mạng xã hội khi hover */
        .footer-social a {
            color: white;
            margin-right: 10px;
            font-size: 22px;
            transition: transform 0.3s ease, color 0.3s ease, filter 0.3s ease;
            filter: drop-shadow(0 0 2px #ffcc00);
            display: inline-block;
        }

            .footer-social a:hover {
                color: #ffc107;
                transform: scale(1.3) rotate(10deg);
                filter: drop-shadow(0 0 8px #ffc107);
            }

        .footer-icon {
            font-size: 2.2rem;
            color: #FFD700;
            margin-bottom: 10px;
            animation: pulseGlow 2s infinite;
        }

        @@keyframes pulseGlow {
            0% {
                text-shadow: 0 0 5px #FFD700;
                transform: scale(1);
            }

            50% {
                text-shadow: 0 0 20px #fff066;
                transform: scale(1.1);
            }

            100% {
                text-shadow: 0 0 5px #FFD700;
                transform: scale(1);
            }
        }

        .link-wrapper a {
            color: #eee;
            text-decoration: none;
            position: relative;
            transition: color 0.3s ease;
        }

            .link-wrapper a::after {
                content: '';
                position: absolute;
                left: 0;
                bottom: -2px;
                height: 2px;
                width: 0%;
                background: #FFD700;
                transition: width 0.3s ease;
            }

            .link-wrapper a:hover {
                color: #FFD700;
            }

                .link-wrapper a:hover::after {
                    width: 100%;
                }

    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a id="brandLink" class="navbar-brand studio-title d-flex align-items-center" href="/Identity/Homepage" data-href="/Identity/Homepage">
                <i class="fas fa-music me-2"></i> ZANEE'S MUSIC STUDIO
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    @{
                        var role = Context.Session.GetString("role");
                        var username = Context.Session.GetString("username");
                    }

                    @if (string.IsNullOrEmpty(role) || role != "admin")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="ServiceHistory" asp-action="RecordingHistory"> 🎶 Lịch sử </a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Feedbacks" asp-action="Index"> 🌟 Đánh giá </a></li>
                    }

                    @if (!string.IsNullOrEmpty(username))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#editUserModal">
                                👤 @username (@role)
                            </a>
                        </li>
                        <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="nav-item">
                            <button type="submit" class="nav-link btn btn-danger text-white border-0">
                                🚪 Đăng xuất
                            </button>
                        </form>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <div class="container footer-flex">
        <div class="link-wrapper icon-column">
            <i class="footer-icon fas fa-music"></i>
            <h4>ZANEE'S MUSIC STUDIO</h4>
            <p>Studio giúp đáp ứng mọi đam mê về âm nhạc của bạn.</p>
            <p>Đến trải nghiệm các dịch vụ chuyên nghiệp của chúng tôi ngay hôm nay!</p>
            <!-- Sóng nhạc dưới cột đầu -->
            <div class="music-wave">
                <span></span><span></span><span></span><span></span><span></span>
            </div>
        </div>

        <div class="link-wrapper icon-column">
            <i class="footer-icon fas fa-link"></i>
            <h4>LIÊN KẾT NHANH</h4>
            <ul>
                <li><a href="#">Cho thuê phòng tập</a></li>
                <li><a href="#">Cho thuê nhạc cụ</a></li>
                <li><a href="#">Dịch vụ thu âm</a></li>
                <li><a href="#">Dịch vụ làm nhạc</a></li>
            </ul>
        </div>

        <div class="link-wrapper icon-column">
            <i class="footer-icon fas fa-share-alt"></i>
            <h4>KẾT NỐI VỚI CHÚNG TÔI</h4>
            <div class="footer-social">
                <a href="#"><i class="fab fa-facebook-f"></i></a>
                <a href="#"><i class="fab fa-tiktok"></i></a>
                <a href="#"><i class="fab fa-instagram"></i></a>
            </div>
        </div>
    </div>

    <div class="footer text-center mt-4">
        © 2025 Zanee's Music Studio Corporation. All rights reserved.
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Điều hướng khi click logo navbar (fade-out)
        document.addEventListener("DOMContentLoaded", function () {
            const brandLink = document.getElementById("brandLink");
            if (brandLink) {
                brandLink.addEventListener("click", function (e) {
                    e.preventDefault();
                    document.body.classList.add("fade-out", "active");
                    setTimeout(() => {
                        window.location.href = this.getAttribute("data-href");
                    }, 500);
                });
            }
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
