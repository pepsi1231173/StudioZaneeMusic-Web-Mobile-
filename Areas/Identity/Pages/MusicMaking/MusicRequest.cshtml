@page
@model DuAnBai3.Pages.MusicRequestModel
@{
    ViewData["Title"] = "Dịch Vụ Làm Nhạc";
    Layout = "~/Areas/Identity/Pages/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Lobster&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<style>
    body {
        background: url('/images/day_background.gif') no-repeat center center fixed;
        background-size: cover;
        color: white;
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
    }

    .container {
        margin-top: 100px !important;
        margin-bottom: 50px !important;
        background: rgba(32, 140, 154, 0.5);
        border-radius: 10px;
        padding: 30px;
        max-width: 600px;
        width: 90%;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);
        text-align: center;
        margin: 40px auto;
    }

    .title {
        font-family: 'Lobster', cursive;
        font-weight: bold;
        letter-spacing: 2.2px;
        color: #FFD700;
        text-shadow: 3px 3px 8px rgba(17, 17, 17, 0.7);
        font-size: 40px;
    }

    .form-group {
        text-align: left;
        margin-top: 25px;
        margin-bottom: 25px;
        color: white;
        position: relative;
    }

    .form-label {
        font-weight: bold;
        display: block;
        margin-bottom: 5px;
        font-size: 1.2rem;
    }

    .form-control {
        border-radius: 6px;
        padding: 10px;
        font-size: 1rem;
        border: none;
        outline: none;
    }

    button {
        background: linear-gradient(45deg, #ff0066, #ffcc00);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 18px;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
        width: 100%;
    }

        button:hover {
            background: linear-gradient(45deg, #ffcc00, #ff0066);
            transform: scale(1.05);
        }
</style>

<div class="container">
    <h2 class="title">🎼 Dịch Vụ Làm Nhạc 🎶</h2>

    <form method="post">
        <div class="form-group">
            <label class="form-label">Thể loại nhạc:</label>
            <input asp-for="Input.MusicGenre" class="form-control" placeholder="Nhập thể loại nhạc mong muốn..." />
            <span asp-validation-for="Input.MusicGenre" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="form-label">Mô tả yêu cầu:</label>
            <textarea asp-for="Input.MusicDescription" class="form-control" rows="3" placeholder="Mô tả chi tiết yêu cầu của bạn..."></textarea>
            <span asp-validation-for="Input.MusicDescription" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="form-label">Họ và tên:</label>
            <input asp-for="Input.CustomerName" class="form-control" placeholder="Nhập họ và tên" />
            <span asp-validation-for="Input.CustomerName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="form-label">Email:</label>
            <input asp-for="Input.CustomerEmail" class="form-control" placeholder="Nhập email" />
            <span asp-validation-for="Input.CustomerEmail" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="form-label">Số điện thoại:</label>
            <input asp-for="Input.CustomerPhone" class="form-control" placeholder="Nhập số điện thoại" />
            <span asp-validation-for="Input.CustomerPhone" class="text-danger"></span>
        </div>

        <button type="submit">🚀 Gửi Yêu Cầu</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
