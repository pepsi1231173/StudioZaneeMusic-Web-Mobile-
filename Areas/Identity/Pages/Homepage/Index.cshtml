@page
@model DuAnBai3.Areas.Identity.Pages.HomepageModel
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    Layout = null;
    var success = Request.Query["success"];
    bool showSuccess = success == "1";
    var username = HttpContextAccessor.HttpContext.Session.GetString("username");
    var email = HttpContextAccessor.HttpContext.Session.GetString("email");
    var role = HttpContextAccessor.HttpContext.Session.GetString("role");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trang chủ - Zanee's Music Studio</title>

    <!-- Font & CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Lobster&display=swap" rel="stylesheet">

    <style>
        body {
            background: url('/images/background.jpg') no-repeat center center;
            background-size: cover;
            color: white;
            text-align: center;
            font-family: 'Lobster', cursive;
        }

        h1 {
            font-size: 45px;
            color: #FFD700;
            text-shadow: 3px 3px 8px rgba(112, 99, 25, 0.7);
            animation: glowPulse 2.5s ease-in-out infinite alternate;
        }

        @@keyframes glowPulse {
            0% {
                text-shadow: 0 0 3px #fff, 0 0 10px #ffdd00;
            }

            100% {
                text-shadow: 0 0 10px #fff, 0 0 30px #ffdd00;
            }
        }

        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            background-color: transparent;
        }

        .navbar-brand {
            font-size: 2rem;
            font-weight: bold;
            color: white !important;
            animation: glowPulse 2s ease-in-out infinite alternate;
        }

        .nav-link {
            font-size: 1.2rem;
            color: white !important;
        }

            .nav-link:hover {
                color: #ffcc70 !important;
                text-decoration: underline;
            }

        .container {
            padding-top: 100px;
            padding-bottom: 60px;
            max-width: 900px;
        }

        .service-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            margin: auto;
            max-width: 600px;
        }

        .service-box {
            height: 180px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 18px;
            color: white;
            background-size: cover;
            background-position: center;
            border: 3px solid rgba(255, 215, 0, 0.8);
            box-shadow: 0 0 15px rgba(255, 215, 0, 0.5);
            transition: transform 0.3s ease;
            cursor: pointer;
            position: relative;
        }

            .service-box:hover {
                transform: scale(1.05);
            }

            .service-box h3 {
                position: absolute;
                bottom: 10px;
                width: 100%;
                background: rgba(0, 0, 0, 0.5);
                padding: 10px;
                margin: 0;
                font-size: 16px;
            }

        .service-room {
            background-image: url('/images/room.jpg');
        }

        .service-instrument {
            background-image: url('/images/instrument.jpg');
        }

        .service-recording {
            background-image: url('/images/recording.jpg');
        }

        .service-music {
            background-image: url('/images/music.jpg');
        }

        .footer {
            font-size: 14px;
            color: #ccc;
            margin-top: 80px;
        }

        .disco-lights {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            background: radial-gradient(circle at 20% 50%, rgba(255, 0, 150, 0.25), transparent 60%), radial-gradient(circle at 50% 50%, rgba(255, 255, 0, 0.25), transparent 60%), radial-gradient(circle at 80% 50%, rgba(0, 200, 255, 0.25), transparent 60%);
            background-blend-mode: screen;
            animation: multiColorFlash 8s linear infinite;
            opacity: 0.3;
        }

        @@keyframes multiColorFlash {
            0% {
                filter: hue-rotate(0deg) brightness(1.2);
            }

            25% {
                filter: hue-rotate(90deg) brightness(1.4);
            }

            50% {
                filter: hue-rotate(180deg) brightness(1.3);
            }

            75% {
                filter: hue-rotate(270deg) brightness(1.5);
            }

            100% {
                filter: hue-rotate(360deg) brightness(1.2);
            }
        }


        .fade-out {
            opacity: 1;
            transition: opacity 0.5s ease-in-out;
        }

            .fade-out.active {
                opacity: 0;
            }

        .footer-flex {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            flex-wrap: wrap;
            gap: 65px;
            padding-top: 40px;
            padding-bottom: 40px;
        }


        .link-wrapper {
            flex: 1 1 28%; /* co giãn đều, mỗi khối tối thiểu 28% */
            color: #ddd;
            font-family: 'Lobster', cursive;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

            .link-wrapper h4 {
                color: #FFD700;
                margin-bottom: 12px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 1.3px;
                display: inline-block;
                position: relative;
            }

                .link-wrapper h4::after {
                    content: "";
                    position: absolute;
                    left: 0;
                    bottom: -4px;
                    width: 100%;
                    height: 2px;
                    background-color: #FFD700;
                }

            .link-wrapper ul {
                list-style: none;
                padding-left: 0;
                margin-left: 0;
                font-size: 0.95rem;
                line-height: 1.4;
                width: 100%;
            }

                .link-wrapper ul li {
                    display: flex;
                    align-items: center;
                    margin-bottom: 6px;
                    font-size: 0.95rem;
                    line-height: 1.4;
                    padding-left: 2px;
                }

                    /* Hiệu ứng icon 🎵 nhấp nháy nhẹ ở LIÊN KẾT NHANH */
                    .link-wrapper ul li::before {
                        content: "🎵";
                        color: #ffcc00;
                        font-size: 1rem;
                        margin-right: 6px;
                        display: inline-block;
                        animation: pulseIcon 2.5s infinite;
                    }

        @@keyframes pulseIcon {
            0%, 100% {
                opacity: 1;
                color: #ffcc00;
                transform: scale(1);
            }

            50% {
                opacity: 0.6;
                color: #ffd633;
                transform: scale(1.2);
            }
        }

        /* Hiệu ứng tiêu đề cột footer (h4) nhẹ rung và đổi màu */
        .link-wrapper h4 {
            position: relative;
            display: inline-block;
            animation: flickerText 3s infinite ease-in-out;
            cursor: default;
            color: #FFD700;
        }

        @@keyframes flickerText {
            0%, 100% {
                text-shadow: 0 0 6px #ffd633;
                color: #FFD700;
            }

            50% {
                text-shadow: 0 0 20px #fff;
                color: #fff8b0;
            }
        }

        /* Hiệu ứng icon mạng xã hội khi hover */
        .footer-social a {
            color: white;
            margin-right: 10px;
            font-size: 22px;
            transition: transform 0.3s ease, color 0.3s ease, filter 0.3s ease;
            filter: drop-shadow(0 0 2px #ffcc00);
            display: inline-block;
        }

            .footer-social a:hover {
                color: #ffc107;
                transform: scale(1.3) rotate(10deg);
                filter: drop-shadow(0 0 8px #ffc107);
            }

        .footer-icon {
            font-size: 2.2rem;
            color: #FFD700;
            margin-bottom: 10px;
            animation: pulseGlow 2s infinite;
        }

        @@keyframes pulseGlow {
            0% {
                text-shadow: 0 0 5px #FFD700;
                transform: scale(1);
            }

            50% {
                text-shadow: 0 0 20px #fff066;
                transform: scale(1.1);
            }

            100% {
                text-shadow: 0 0 5px #FFD700;
                transform: scale(1);
            }
        }

        .link-wrapper a {
            color: #eee;
            text-decoration: none;
            position: relative;
            transition: color 0.3s ease;
        }

            .link-wrapper a::after {
                content: '';
                position: absolute;
                left: 0;
                bottom: -2px;
                height: 2px;
                width: 0%;
                background: #FFD700;
                transition: width 0.3s ease;
            }

            .link-wrapper a:hover {
                color: #FFD700;
            }

                .link-wrapper a:hover::after {
                    width: 100%;
                }

        .music-avatar {
            width: 160px;
            height: 160px;
            border-radius: 50%;
            border: 4px solid #fff;
            background: linear-gradient(45deg, #ff00ff, #00ffff, #ffff00);
            box-shadow: 0 0 20px #ff00ff, 0 0 30px #00ffff, 0 0 40px #ffff00;
            transition: box-shadow 0.3s ease-in-out, transform 0.2s;
        }

            .music-avatar:hover {
                box-shadow: 0 0 30px #ff00ff, 0 0 45px #00ffff, 0 0 60px #ffff00, 0 0 80px #ff00ff;
                transform: scale(1.05);
            }


        .music-avatar-sm {
            width: 35px;
            height: 35px;
            border: 2px solid #fff;
            box-shadow: 0 0 5px #ff00ff, 0 0 10px #00ffff, 0 0 15px #ffff00;
            transition: box-shadow 0.3s ease-in-out, transform 0.2s;
        }

            .music-avatar-sm:hover {
                box-shadow: 0 0 10px #ff00ff, 0 0 15px #00ffff, 0 0 20px #ffff00, 0 0 25px #ff00ff;
                transform: scale(1.1);
            }
    </style>
</head>

<body>
    @await Html.PartialAsync("_IntroLoading")
    @if (showSuccess)
    {
        <script>
            window.onload = function () {
                alert('Cập nhật thông tin thành công!');
            };
        </script>
    }

    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a id="brandLink" class="navbar-brand" data-href="/Identity/Homepage">
                <i class="fas fa-music me-2"></i> ZANEE'S MUSIC STUDIO
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/Identity/Homepage">🏠 Trang chủ</a></li>
                    @if (string.IsNullOrEmpty(role) || role != "admin")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="ServiceHistory" asp-action="RecordingHistory">🎶 Lịch sử</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Feedbacks" asp-action="Index">📞 Liên hệ</a></li>
                    }
                    @if (!string.IsNullOrEmpty(username))
                    {
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#editUserModal" style="cursor:pointer;">
                                <img src="@Model.Avatar" alt="Avatar" class="rounded-circle music-avatar-sm me-2" />
                                @username
                            </a>
                        </li>

                        <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="nav-item">
                            <button type="submit" class="nav-link btn btn-danger text-white border-0">🚪 Đăng xuất</button>
                        </form>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <!-- Modal Cập nhật thông tin -->
    <div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark text-white">
                <div class="modal-header border-0">
                    <h5 class="modal-title" id="editUserModalLabel">
                        <i class="fas fa-user-edit me-2"></i> Cập nhật thông tin cá nhân
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" enctype="multipart/form-data" asp-page-handler="UpdateProfile">
                    <div class="modal-body">
                        <div class="row g-3">
                            <!-- Avatar -->
                            <div class="col-md-4 text-center">
                                <img src="@Model.Avatar" alt="Avatar" class="rounded-circle music-avatar shadow" id="previewAvatar" style="cursor:pointer;" />
                                <input type="file" name="AvatarFile" accept="image/*" id="avatarInput" style="display:none;"
                                       onchange="document.getElementById('previewAvatar').src = window.URL.createObjectURL(this.files[0])">
                            </div>

                            <!-- Thông tin -->
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label class="form-label">Họ và tên</label>
                                    <input type="text" class="form-control" name="FullName" value="@Model.FullName">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Tên đăng nhập</label>
                                    <input type="text" class="form-control" name="Username" value="@Model.Username">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Email</label>
                                    <input type="email" class="form-control" name="Email" value="@Model.Email">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Số điện thoại</label>
                                    <input type="text" class="form-control" name="PhoneNumber" value="@Model.PhoneNumber">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Mật khẩu cũ</label>
                                    <input type="password" class="form-control" name="CurrentPassword" placeholder="Nhập mật khẩu hiện tại">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Mật khẩu mới</label>
                                    <input type="password" class="form-control" name="NewPassword" placeholder="Để trống nếu không đổi mật khẩu">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-warning">Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="container">
        <h1 class="glow-animation">Chào mừng đến với Zanee's Music Studio!</h1>
        <p class="fs-4">Chúng mình có các dịch vụ</p>

        <div class="service-container">
            <div class="service-box service-room" data-href="/Identity/Rooms"><h3>Cho thuê phòng tập</h3></div>
            <div class="service-box service-instrument" data-href="@Url.Page("/Instruments/List", new { area = "Identity" })"><h3>Cho thuê nhạc cụ</h3></div>

            <div class="service-box service-recording" data-href="@Url.Page("/Recording/Recording", new { area = "Identity" })"><h3>Dịch vụ thu âm </h3></div>

            <div class="service-box service-music" data-href="@Url.Page("/MusicMaking/MuSicRequest", new { area = "Identity" })"><h3>Dịch vụ làm nhạc </h3></div>
        </div>
    </div>
    <div class="container footer-flex">
        <div class="link-wrapper icon-column">
            <i class="footer-icon fas fa-music"></i>
            <h4>ZANEE'S MUSIC STUDIO</h4>
            <p>Studio giúp đáp ứng mọi đam mê về âm nhạc của bạn.</p>
            <p>Đến trải nghiệm các dịch vụ chuyên nghiệp của chúng tôi ngay hôm nay!</p>
            <!-- Sóng nhạc dưới cột đầu -->
            <div class="music-wave">
                <span></span><span></span><span></span><span></span><span></span>
            </div>
        </div>

        <div class="link-wrapper icon-column">
            <i class="footer-icon fas fa-link"></i>
            <h4>LIÊN KẾT NHANH</h4>
            <ul>
                <li><a href="/Identity/Rooms">Cho thuê phòng tập</a></li>
                <li><a href="/Identity/Instruments/List">Cho thuê nhạc cụ</a></li>
                <li><a href="/Identity/Recording/Recording">Dịch vụ thu âm</a></li>
                <li><a href="#">Dịch vụ làm nhạc</a></li>
            </ul>
        </div>

        <div class="link-wrapper icon-column">
            <i class="footer-icon fas fa-share-alt"></i>
            <h4>KẾT NỐI VỚI CHÚNG TÔI</h4>
            <div class="footer-social">
                <a href="https://www.facebook.com/tdkhuee"><i class="fab fa-facebook-f"></i></a>
                <a href="https://www.youtube.com/@@zanee_derapper"><i class="fab fa-youtube"></i></a>
                <a href="https://www.tiktok.com/@@zanee_derapper?lang=en"><i class="fab fa-tiktok"></i></a>
            </div>
        </div>
    </div>
    <div class="footer text-center">
        © 2025 Zanee's Music Studio. All rights reserved.
    </div>

    <div class="disco-lights"></div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const fadeAndNavigate = (el) => {
                const href = el.getAttribute("data-href");
                if (href) {
                    document.body.classList.add("fade-out", "active");
                    setTimeout(() => {
                        window.location.href = href;
                    }, 500);
                }
            };

            document.querySelectorAll(".service-box").forEach(box => {
                box.addEventListener("click", () => fadeAndNavigate(box));
            });

            const brand = document.getElementById("brandLink");
            if (brand) {
                brand.addEventListener("click", (e) => {
                    e.preventDefault();
                    fadeAndNavigate(brand);
                });
            }
        });
    </script>
    <script>
        document.getElementById('previewAvatar').addEventListener('click', function () {
            document.getElementById('avatarInput').click();
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
