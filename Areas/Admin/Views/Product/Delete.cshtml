@model DuAnBai3.Models.Product

@{
    ViewData["Title"] = "Xóa Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: url('/images/background.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Poppins', sans-serif;
        color: #fff;
    }

    .delete-container {
        background-color: rgba(0, 0, 0, 0.8);
        padding: 40px;
        border-radius: 16px;
        max-width: 700px;
        margin: 50px auto;
        box-shadow: 0 0 20px rgba(255, 0, 0, 0.3);
    }

    h1, h3, h4 {
        text-align: center;
        color: #ff4d4d;
        text-shadow: 1px 1px 3px #000;
    }

    .dl-horizontal dt {
        font-weight: bold;
        color: #0dcaf0;
    }

    .dl-horizontal dd {
        color: #f8f9fa;
    }

    .btn-danger {
        width: 150px;
        background-color: #dc3545;
        font-weight: bold;
        border-radius: 8px;
    }

    .btn-secondary {
        width: 150px;
        border-radius: 8px;
    }

    .btn-wrapper {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-top: 30px;
    }
</style>

<div class="delete-container">
    <h1>Xác Nhận Xóa</h1>
    <h3>Bạn có chắc chắn muốn xóa sản phẩm này?</h3>
    <hr />

    <dl class="row dl-horizontal">
        <dt class="col-sm-4">Tên sản phẩm</dt>
        <dd class="col-sm-8">@Model.Name</dd>

        <dt class="col-sm-4">Giá</dt>
        <dd class="col-sm-8">@Model.Price</dd>

        <dt class="col-sm-4">Mô tả</dt>
        <dd class="col-sm-8">@Model.Description</dd>

        <dt class="col-sm-4">Hình ảnh</dt>
        <dd class="col-sm-8">
            <img src="@Model.ImageUrl" alt="Product Image" style="max-width: 100%; height: auto; border-radius: 10px;" />
        </dd>

        <dt class="col-sm-4">Danh mục</dt>
        <dd class="col-sm-8">@Model.Category?.Name</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="btn-wrapper">
            <input type="submit" value="🗑️ Xóa" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary">🔙 Quay lại</a>
        </div>
    </form>
</div>
