@model IEnumerable<DuAnBai3.Models.Product>

@{
    ViewData["Title"] = "Danh Sách Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background-color: #121212;
        color: #fff;
    }

    h2 {
        font-weight: 700;
        letter-spacing: 1px;
        text-shadow: 0 0 10px rgba(255, 255, 0, 0.5);
    }

    table {
        background-color: #1f1f1f;
        border-radius: 10px;
        overflow: hidden;
    }

    thead {
        background: linear-gradient(90deg, #ffcc00, #ff9900);
        color: #000;
        font-weight: bold;
    }

    .img-thumbnail {
        border: 2px solid #ffcc00;
        box-shadow: 0 0 10px rgba(255, 204, 0, 0.3);
        transition: transform 0.2s ease-in-out;
    }

        .img-thumbnail:hover {
            transform: scale(1.1);
        }

    .badge {
        font-size: 0.9rem;
        padding: 8px 12px;
    }

    .btn {
        border-radius: 10px;
        font-weight: 600;
    }

    .btn-warning {
        color: #000;
    }

    .btn-info {
        color: #fff;
    }

    .btn-danger {
        color: #fff;
    }
</style>

<h2 class="text-center mt-4 mb-4 text-warning">📦 Danh Sách Sản Phẩm</h2>

<div class="container">
    <div class="mb-3 text-end">
        <a asp-action="Create" class="btn btn-success shadow-sm">➕ Thêm sản phẩm</a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover text-center align-middle">
            <thead>
                <tr>
                    <th>Tên</th>
                    <th>Giá</th>
                    <th>Mô Tả</th>
                    <th>Danh Mục</th>
                    <th>Hình Ảnh</th>
                    <th>Trạng Thái</th>
                    <th>Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var product in Model)
                    {
                        <tr>
                            <td class="fw-bold text-warning">@product.Name</td>
                            <td>@($"{product.Price:N0} đ")</td>
                            <td>@product.Description</td>
                            <td>@product.Category?.Name</td>
                            <td>
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="Ảnh sản phẩm" width="100" height="100" class="img-thumbnail" />
                                }
                                else
                                {
                                    <span class="text-secondary fst-italic">Chưa có ảnh</span>
                                }
                            </td>
                            <td>
                                @if (product.IsUnderMaintenance)
                                {
                                    <span class="badge bg-warning text-dark">🛠 Đang bảo trì</span>
                                }
                                else if (product.IsRented)
                                {
                                    <span class="badge bg-danger">🚫 Đang thuê</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">✅ Sẵn sàng</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-warning me-1">✏️ Sửa</a>
                                <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-info me-1">🔍 Xem</a>
                                <a asp-action="Delete" asp-route-id="@product.Id"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này không?');">
                                    🗑️ Xóa
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Không có sản phẩm nào để hiển thị 😢
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
