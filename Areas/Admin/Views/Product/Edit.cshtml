@model DuAnBai3.Models.Product
@{
    ViewData["Title"] = "Sửa sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<h2 class="text-light">Chỉnh sửa sản phẩm</h2>

<form asp-action="Edit" enctype="multipart/form-data" method="post" class="bg-dark text-light p-4 rounded shadow">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Tên sản phẩm</label>
        <input asp-for="Name" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Giá</label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Danh mục</label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select" required></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Mô tả</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Hình ảnh hiện tại</label><br />
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="Ảnh hiện tại" style="max-width:200px; border-radius:8px;" />
        }
    </div>

    <div class="mb-3">
        <label class="form-label">Chọn ảnh mới (nếu muốn thay)</label>
        <input type="file" name="ImageFile" class="form-control" accept="image/*" onchange="previewImage(event)" />
        <img id="preview" src="#" alt="Preview" class="mt-3" style="display:none; max-width:200px;" />
    </div>

    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function previewImage(event) {
            const preview = document.getElementById('preview');
            preview.src = URL.createObjectURL(event.target.files[0]);
            preview.style.display = 'block';
        }
    </script>
}
