@{
    ViewData["Title"] = "Thống kê hệ thống";
    var data = ViewBag.ChartData;
    var totalRevenue = ViewBag.TotalRevenue ?? 0;
    var totalBookings = ViewBag.TotalBookings ?? 0;
    var totalInstruments = ViewBag.TotalInstruments ?? 0;
    var totalMusicRequests = ViewBag.TotalMusicRequests ?? 0;
    var totalRecordings = ViewBag.TotalRecordings ?? 0;
    var totalUsers = ViewBag.TotalUsers ?? 0; // Thống kê người dùng
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body {
        background: url('/images/background.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Poppins', sans-serif;
    }

    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        border-left: 6px solid #0d6efd;
        transition: transform 0.2s ease-in-out;
    }

        .stat-card:hover {
            transform: scale(1.03);
        }

    .chart-container {
        background: white;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    h2, h4 {
        color: white;
    }
</style>

<div class="container mt-5">
    <h2 class="text-center mb-4">📊 Thống kê hệ thống</h2>

    <div class="row row-cols-1 row-cols-md-5 g-4 mb-4">
        <div class="col">
            <div class="stat-card">
                <h5>Tổng doanh thu</h5>
                <p class="fs-4 text-success">@totalRevenue.ToString("N0") VNĐ</p>
            </div>
        </div>
        <div class="col">
            <div class="stat-card">
                <h5>Đơn đặt phòng</h5>
                <p class="fs-4">@totalBookings</p>
            </div>
        </div>
        <div class="col">
            <div class="stat-card">
                <h5>Thuê nhạc cụ</h5>
                <p class="fs-4">@totalInstruments</p>
            </div>
        </div>
        <div class="col">
            <div class="stat-card">
                <h5>Ghi âm</h5>
                <p class="fs-4">@totalRecordings</p>
            </div>
        </div>
        <div class="col">
            <div class="stat-card">
                <h5>Tổng người dùng</h5>
                <p class="fs-4">@totalUsers</p>
            </div>
        </div>
    </div>

    <div class="chart-container mb-5">
        <h4 class="mb-3">Biểu đồ số lượng hoạt động</h4>
        <canvas id="myChart" height="120"></canvas>
    </div>

    <a href="/Admin/Homepage/Dashboard" class="btn btn-secondary mt-3">🔙 Quay lại</a>
</div>

<script>
    const ctx = document.getElementById('myChart').getContext('2d');

    const gradient = ctx.createLinearGradient(0, 0, 0, 400);
    gradient.addColorStop(0, '#4facfe');
    gradient.addColorStop(1, '#00f2fe');

    const chart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: @Html.Raw(Json.Serialize(data.labels)),
            datasets: [{
                label: 'Số lượng',
                data: @Html.Raw(Json.Serialize(data.counts)),
                backgroundColor: gradient,
                borderColor: '#007bff',
                borderWidth: 1,
                borderRadius: 12,
                hoverBackgroundColor: '#3399ff',
                hoverBorderColor: '#0056b3'
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: '#fff',
                    titleColor: '#000',
                    bodyColor: '#333',
                    borderColor: '#ccc',
                    borderWidth: 1
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { precision: 0 },
                    grid: {
                        color: "rgba(0,0,0,0.05)"
                    }
                },
                x: {
                    grid: {
                        display: false
                    }
                }
            }
        }
    });
</script>
