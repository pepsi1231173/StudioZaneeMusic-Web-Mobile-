@model IEnumerable<DuAnBai3.Models.Category>

@{
    ViewData["Title"] = "Danh sách danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />

<style>
    body {
        background: url('/images/background.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Poppins', sans-serif;
    }

    html, body {
        overflow-x: hidden !important;
    }

    .form-wrapper {
        max-width: 800px;
        margin: 50px auto;
        padding: 30px;
        background-color: rgba(255, 255, 255, 0.95);
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    }

    h2 {
        text-align: center;
        margin-bottom: 25px;
        font-weight: bold;
        color: #333;
    }

    .btn-primary, .btn-success, .btn-warning, .btn-danger {
        border: none;
    }

    table {
        background-color: white;
    }

    .table th {
        text-align: center;
    }

    .table td {
        vertical-align: middle;
    }
</style>

<div class="form-wrapper">
    <h2>📂 Danh sách danh mục</h2>

    

    <table class="table table-bordered table-hover">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Tên danh mục</th>
                <th style="width: 150px;">Thao tác</th>
			</tr>
		<a href="@Url.Action("Add")" class="btn btn-success mb-3">➕ Thêm danh mục</a>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>
                        <a href="@Url.Action("Update", new { id = item.Id })" class="btn btn-warning btn-sm">✏️ Sửa</a><br />
                        <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc muốn xóa danh mục này?');">🗑️ Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<a href="/Admin/Homepage/Dashboard" class="btn btn-secondary mt-4">🔙 Quay lại</a>