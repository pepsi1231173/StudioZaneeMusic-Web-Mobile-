@model List<DuAnBai3.Models.RecordingBooking>
@{
    ViewData["Title"] = "Quản lý đơn thu âm";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<style>
    body {
        background: url('/images/background.jpg') no-repeat center center fixed;
        background-size: cover;
    }
    html, body {
        overflow-x: hidden !important;
    }
    .recording-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        border-left: 6px solid #6b6919;
    }
    .label-col { font-weight: bold; color: #333; }
    .value-col { color: #555; }
</style>

<div class="container mt-5">
    <h2 class="text-center text-white mb-4">🎙️ Danh sách đơn dịch vụ thu âm</h2>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                var status = item.Status?.ToLower() ?? "";
                var (statusText, badgeColor) = status switch
                {
                    "pending" => ("Chờ duyệt", "warning"),
                    "confirmed" => ("Đã xác nhận", "success"),
                    "canceled" => ("Đã hủy", "danger"),
                    _ => ("Không xác định", "secondary")
                };

                <div class="col-md-6">
                    <div class="recording-card">
                        <div class="row mb-2"><div class="col-4 label-col">Mã đơn:</div><div class="col-8 value-col">#@item.Id</div></div>
                        <div class="row mb-2"><div class="col-4 label-col">Khách hàng:</div><div class="col-8 value-col">@item.CustomerName</div></div>
                        <div class="row mb-2"><div class="col-4 label-col">SĐT:</div><div class="col-8 value-col">@item.CustomerPhone</div></div>
                        <div class="row mb-2"><div class="col-4 label-col">Email:</div><div class="col-8 value-col">@item.CustomerEmail</div></div>
                        <div class="row mb-2"><div class="col-4 label-col">Gói thu âm:</div><div class="col-8 value-col">@item.RecordingPackage</div></div>
                        <div class="row mb-2"><div class="col-4 label-col">Ngày:</div><div class="col-8 value-col">@item.RecordingDate.ToString("dd/MM/yyyy")</div></div>
                        <div class="row mb-2">
                            <div class="col-4 label-col">Thời gian:</div>
                            <div class="col-8 value-col">
                                @{
                                    var start = item.RecordingTime;
                                    var end = start + TimeSpan.FromHours(item.Duration);
                                }
                                @start.ToString(@"hh\:mm") - @end.ToString(@"hh\:mm")
                            </div>
                        </div>

                        <div class="row mb-2"><div class="col-4 label-col">Giá:</div><div class="col-8 value-col">@item.Price.ToString("N0") VNĐ</div></div>
                        <div class="row mb-3">
                            <div class="col-4 label-col">Trạng thái:</div>
                            <div class="col-8 value-col"><span class="badge bg-@badgeColor">@statusText</span></div>
                        </div>

                        @* Nút thao tác theo trạng thái *@
                        @if (status == "pending")
                        {
                            <form method="post" asp-area="Admin" asp-controller="RecordingBooking" asp-action="Confirm" style="display:inline-block;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-success btn-sm me-2">✅ Xác nhận</button>
                            </form>

                            <form method="post" asp-area="Admin" asp-controller="RecordingBooking" asp-action="Cancel" style="display:inline-block;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-danger btn-sm me-2">❌ Hủy đơn</button>
                            </form>
                        }

                        @* Luôn hiển thị xóa vĩnh viễn nếu không pending *@
                        @if (status != "pending")
                        {
                            <form method="post" asp-area="Admin" asp-controller="RecordingBooking" asp-action="Delete" style="display:inline-block;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-dark btn-sm">🗑 Xóa </button>
                            </form>
                        }

                        @if (status == "canceled")
                        {
                            <p class="text-danger mt-2">Đơn đã bị hủy.</p>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center">Chưa có đơn thu âm nào.</div>
    }

    <a href="/Admin/Homepage/Dashboard" class="btn btn-secondary mt-4">🔙 Quay lại</a>
</div>
