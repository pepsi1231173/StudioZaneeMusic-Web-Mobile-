@model DuAnBai3.Models.ManageUserRolesViewModel

@{
    ViewData["Title"] = "Phân quyền User";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}
<style>
    body {
        background: url('/images/background.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Poppins', sans-serif;
    }

    .page-header-modern {
        padding: 30px 0;
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
    }

        .page-header-modern h1 {
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

    .breadcrumb {
        background-color: transparent;
        padding: 0;
        margin: 0;
    }

    .breadcrumb-item a {
        color: #ffc107;
        text-decoration: none;
    }

    .breadcrumb-item.active {
        color: #f8f9fa;
    }

    .user-card {
        background-color: #ffffff;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
        transition: all 0.3s ease;
    }

        .user-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
        }

    .card-header {
        background-color: #f8f9fa;
        padding: 20px 25px;
        border-bottom: 1px solid #dee2e6;
        border-radius: 16px 16px 0 0;
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: #343a40;
    }

    .text-warning {
        color: #ffc107 !important;
        font-weight: bold;
    }

    .card-body {
        padding: 25px;
    }

    .form-check {
        background-color: #f1f3f5;
        padding: 10px 15px;
        border-radius: 8px;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        transition: background-color 0.2s ease;
    }

        .form-check:hover {
            background-color: #e2e6ea;
        }

    .form-check-input {
        margin-right: 10px;
        transform: scale(1.2);
    }

    .form-check-label {
        font-size: 1rem;
        font-weight: 500;
        color: #333;
    }

    .card-footer {
        background-color: #f8f9fa;
        border-top: 1px solid #dee2e6;
        padding: 20px 25px;
        border-radius: 0 0 16px 16px;
    }

    .btn-primary {
        background-color: #007bff;
        border: none;
        font-weight: 500;
        padding: 10px 20px;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

        .btn-primary:hover {
            background-color: #0056b3;
        }

    .btn-light {
        background-color: #e2e6ea;
        color: #333;
        border-radius: 6px;
    }

        .btn-light:hover {
            background-color: #d6d8db;
        }

    .alert-danger {
        background-color: #f8d7da;
        border: none;
        color: #721c24;
        border-radius: 8px;
        padding: 15px 20px;
        margin-bottom: 20px;
    }
}
</style>

<div class="page-header-modern">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1><i class="fas fa-user-shield mr-3"></i>Quản lý phân quyền</h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-action="Index">Users</a></li>
                        <li class="breadcrumb-item active">Phân quyền</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="row">
        <div class="col-lg-8 offset-lg-2">
            <div class="card user-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="card-title">
                        <i class="fas fa-user-cog mr-2"></i>
                        Phân quyền cho: <span class="text-warning">@Model.UserName</span>
                    </h3>
                </div>

                <form asp-action="ManageRoles" method="post">
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="UserName" />
                    <div class="card-body">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger alert-dismissible fade show">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                <strong>Có lỗi xảy ra!</strong>
                                <ul class="mb-0">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }

                        @for (int i = 0; i < Model.UserRoles.Count; i++)
                        {
                            <div class="form-check mb-2">
                                <input type="checkbox" class="form-check-input"
                                       asp-for="UserRoles[i].IsSelected" id="role_@i" />
                                <label class="form-check-label" for="role_@i">
                                    @Model.UserRoles[i].RoleName
                                </label>
                                <input type="hidden" asp-for="UserRoles[i].RoleId" />
                                <input type="hidden" asp-for="UserRoles[i].RoleName" />
                            </div>
                        }
                    </div>

                    <div class="card-footer text-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i> Lưu thay đổi
                        </button>
                    </div>
                </form>
                <a href="/Admin" class="btn btn-secondary mt-4">🔙 Quay lại</a>
            </div>
        </div>
    </div>
</div>