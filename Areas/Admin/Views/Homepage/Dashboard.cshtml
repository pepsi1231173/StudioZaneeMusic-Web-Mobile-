<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Zanee's Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Lobster&family=Poppins:wght@400;600&display=swap" rel="stylesheet">

    <style>
        body {
            background: url('/images/background.jpg') no-repeat center center fixed;
            background-size: cover;
            color: white;
            text-align: center;
        }


        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            background: rgba(0, 0, 0, 0.9);
            padding: 5px 10px;
            border-bottom: 3px solid gold;
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.4);
        }

        .navbar-brand {
            color: gold !important;
            font-size: 30px;
            font-weight: bold;
            font-family: 'Lobster', cursive;
            text-shadow: 0 0 10px gold;
        }

        .nav-link {
            color: white !important;
            font-size: 20px;
            margin: 0 14px;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: #f8d210 !important;
                text-shadow: 0 0 10px gold;
            }

        .dashboard-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            padding: 100px 40px 40px;
            max-width: 1200px;
            margin: auto;
        }

        .box {
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid #FFD700;
            border-radius: 20px;
            padding: 40px 20px;
            text-align: center;
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.4);
            transition: transform 0.4s ease, box-shadow 0.4s ease;
            cursor: pointer;
            backdrop-filter: blur(5px);
        }

            .box:hover {
                transform: translateY(-10px) scale(1.03);
                box-shadow: 0 0 40px rgba(255, 215, 0, 0.8);
            }

            .box i {
                font-size: 48px;
                margin-bottom: 20px;
                color: #FFD700;
            }

            .box h3 {
                font-size: 22px;
                color: white;
                font-weight: bold;
            }

        h1 {
            font-size: 48px;
            margin-top: 100px;
            font-family: 'Lobster', cursive;
            text-shadow: 0 0 10px gold;
            color: gold;
        }

        .neon-text {
            font-family: 'Lobster', cursive;
            font-size: 60px;
            font-weight: 900;
            color: #ffd700;
            text-shadow: 0 0 3px rgba(255, 215, 0, 0.7), 0 0 6px rgba(255, 215, 0, 0.5), 0 0 10px rgba(255, 204, 0, 0.4), 0 0 15px rgba(248, 210, 16, 0.3);
            text-align: center;
            margin-bottom: 30px;
        }



        p {
            color: #fff;
            font-size: 20px;
            font-weight: 700; /* in đậm */
            text-shadow: 0 0 6px rgba(255,255,255,0.3);
        }

        .footer {
            margin-top: 80px;
            font-size: 14px;
            color: #ccc;
        }
    </style>
</head>
<body>
    @await Html.PartialAsync("_IntroLoading")
    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Admin/Homepage/Dashboard">
                🎧 Zanee Admin Studio
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/Admin/Homepage/Dashboard">🏠 Trang chủ</a>
                    </li>
                    <li class="nav-item position-relative">
                        <a class="nav-link" href="/Admin/Feedbacks/Index">
                            <i class="fas fa-comment-dots me-1"></i> Phản hồi
                            <span id="feedbackBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none;">
                                0
                            </span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">👑 Admin</a>
                    </li>
                    <li class="nav-item">
                        <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/Homepage/Dashboard">
                            <button type="submit" class="nav-link btn btn-danger text-white border-0">
                                🚪 Đăng xuất
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <h1 class="neon-text">Chào mừng đến bảng điều khiển Admin</h1>

    <p>Hãy chọn chức năng để bắt đầu quản lý hệ thống âm nhạc 🎼</p>

    <div class="dashboard-container">
        <a asp-area="Admin" asp-controller="Booking" asp-action="Room" class="box">
            <i class="fas fa-door-open"></i>
            <h3>📋 Quản lý phòng tập</h3>
        </a>
        <a asp-area="Admin" asp-controller="Instrument" asp-action="Index" class="box">
            <i class="fas fa-guitar"></i>
            <h3>🎸 Thuê nhạc cụ</h3>
        </a>
        <a asp-area="Admin" asp-controller="RecordingBooking" asp-action="Index" class="box">
            <i class="fas fa-microphone-alt"></i>
            <h3>🎙️ Dịch vụ thu âm</h3>
        </a>
        <a asp-area="Admin" asp-controller="MusicRequest" asp-action="Index" class="box">
            <i class="fas fa-music"></i>
            <h3>🎶 Làm nhạc theo yêu cầu</h3>
        </a>
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="box">
            <i class="fas fa-plus-circle"></i>
            <h3>➕ Thêm nhạc cụ</h3>
        </a>
        <a asp-area="Admin" asp-controller="User" asp-action="Index" class="box">
            <i class="fas fa-users"></i>
            <h3>👥 Quản lý người dùng</h3>
        </a>
        <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="box">
            <i class="fas fa-layer-group"></i>
            <h3>📂 Danh mục</h3>
        </a>
        <a asp-area="Admin" asp-controller="Statistics" asp-action="Index" class="box">
            <i class="fas fa-chart-line"></i>
            <h3>📊 Thống kê</h3>
        </a>
    </div>

    <div class="footer mt-5">
        © 2025 Zanee's Music Studio Corporation. All rights reserved.
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function checkNewFeedback() {
            try {
                const response = await fetch('/Admin/Feedbacks/GetNewFeedbackCount');
                const data = await response.json(); // { count: số feedback mới }

                const badge = document.getElementById('feedbackBadge');

                if (data.count > 0) {
                    badge.textContent = data.count;
                    badge.style.display = 'inline-block';
                } else {
                    badge.style.display = 'none';
                }
            } catch (err) {
                console.error('Lỗi khi kiểm tra feedback mới:', err);
            }
        }

        // Chạy ngay khi load
        checkNewFeedback();
        // Kiểm tra mỗi 30 giây
        setInterval(checkNewFeedback, 30000);
    </script>

</body>
</html>
