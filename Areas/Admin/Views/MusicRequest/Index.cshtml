@model List<DuAnBai3.Models.MusicRequest>
@{
    ViewData["Title"] = "Yêu cầu làm nhạc";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

<style>
    body {
        background: url('/images/background.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Poppins', sans-serif;
    }

    html, body {
        overflow-x: hidden !important;
    }

    .navbar {
        position: fixed;
        padding-top: 3px;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1000;
    }

    .container {
        margin-top: 30px;
        margin-bottom: 50px;
    }

    .music-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        border-left: 6px solid #20c997;
    }
</style>

<div class="container mt-4">
    <h2 class="text-white text-center mb-4">🎵 Danh sách yêu cầu làm nhạc</h2>

    @if (Model.Any())
    {
        <div class="row">
            @foreach (var req in Model)
            {
                <div class="col-md-6">
                    <div class="card p-3 mb-3" style="border-left: 6px solid #20c997;">
                        <p><strong>Mã đơn:</strong> #@req.Id</p>
                        <p><strong>Khách hàng:</strong> @req.CustomerName</p>
                        <p><strong>SĐT:</strong> @req.CustomerPhone</p>
                        <p><strong>Email:</strong> @req.CustomerEmail</p>
                        <p><strong>Thể loại:</strong> @req.MusicGenre</p>
                        <p><strong>Mô tả:</strong> @req.MusicDescription</p>
                        <p><strong>Ngày gửi:</strong> @req.CreatedAt.ToString("dd/MM/yyyy")</p>

                        @{
                            string statusText;
                            string badgeColor;

                            switch (req.Status?.ToLower())
                            {
                                case "pending":
                                    statusText = "Đang chờ";
                                    badgeColor = "warning";
                                    break;
                                case "confirmed":
                                    statusText = "Đã duyệt";
                                    badgeColor = "success";
                                    break;
                                case "canceled":
                                    statusText = "Đã hủy";
                                    badgeColor = "danger";
                                    break;
                                default:
                                    statusText = "Không xác định";
                                    badgeColor = "secondary";
                                    break;
                            }
                        }

                        <p>
                            <strong>Trạng thái:</strong>
                            <span class="badge bg-@badgeColor">@statusText</span>
                        </p>

                        @if (req.Status?.ToLower() == "pending")
                        {
                            <form asp-action="Confirm" method="post" class="d-inline"
                                  onsubmit="return confirm('Xác nhận duyệt đơn này?');">
                                <input type="hidden" name="id" value="@req.Id" />
                                <button type="submit" class="btn btn-success btn-sm mt-2">✅ Xác nhận</button>
                            </form>

                            <form asp-action="Cancel" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn này?');">
                                <input type="hidden" name="id" value="@req.Id" />
                                <button type="submit" class="btn btn-danger btn-sm mt-2">❌ Hủy đơn</button>
                            </form>
                        }
                        else if (req.Status?.ToLower() == "confirmed")
                        {
                            <p class="text-success mt-2">✅ Đơn đã được xác nhận.</p>
                            <form asp-action="Delete" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn có chắc muốn xóa đơn này?');">
                                <input type="hidden" name="id" value="@req.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm mt-2">🗑 Xóa</button>
                            </form>
                        }
                        else if (req.Status?.ToLower() == "canceled")
                        {
                            <p class="text-danger mt-2">❌ Đơn đã bị hủy.</p>
                            <form asp-action="Delete" method="post" class="d-inline"
                                  onsubmit="return confirm('Bạn có chắc muốn xóa đơn này?');">
                                <input type="hidden" name="id" value="@req.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm mt-2">🗑 Xóa</button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center">Chưa có đơn làm nhạc nào.</div>
    }

    <a href="/Admin/Homepage/Dashboard" class="btn btn-secondary mt-4">🔙 Quay lại</a>
</div>
