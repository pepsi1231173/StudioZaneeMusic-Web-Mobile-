@model IEnumerable<DuAnBai3.Models.Category>

<h2>Category</h2>
<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var Category in Model)
        {
            <tr>
                <td>@Category.Name</td>
                <td>
                    <a asp-action="Update" asp-route-id="@Category.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@Category.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}
<p>
    <a asp-action="Add" class="btn btn-primary">Add Category</a>
</p>