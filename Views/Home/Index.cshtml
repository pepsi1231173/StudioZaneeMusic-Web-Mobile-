@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Trang chủ - Zanee's Music Studio";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var username = HttpContextAccessor.HttpContext.Session.GetString("username");
    var isLoggedIn = !string.IsNullOrEmpty(username);
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
    body {
        background-image: url('/images/background.jpg');
        background-attachment: fixed;
        color: #f0f0f0;
        font-family: 'Poppins', sans-serif;
        text-align: center;
        margin: 0;
        padding: 0;
        overflow-x: hidden;
    }

    /* --- SCROLLING TEXT --- */
    .scrolling-text-container {
        position: relative;
        width: 100%;
        overflow: hidden;
        padding: 14px 0;
        margin-top: 50px;
        /* Xóa màu vàng phía sau */
        background: transparent;
        box-shadow: none;
        -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
        mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
        z-index: 9999;
        user-select: none;
    }


    .scrolling-text {
        display: inline-block;
        white-space: nowrap;
        font-size: 2rem;
        font-weight: 700;
        color: #ffd700;
        text-shadow: 0 0 10px #ffd700, 0 0 20px #ffa500;
        animation: scroll-right 18s linear infinite;
    }

    @@keyframes scroll-right {
        0%

    {
        transform: translateX(-100%);
    }

    100% {
        transform: translateX(100%);
    }

    }

    /* --- BUTTONS --- */
    .btn-custom {
        background: linear-gradient(135deg, #ffb347, #ffcc33);
        border: none;
        padding: 14px 36px;
        font-size: 18px;
        font-weight: 700;
        border-radius: 30px;
        color: #222;
        box-shadow: 0 8px 15px rgba(255, 204, 51, 0.7);
        transition: all 0.3s ease;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        user-select: none;
        filter: drop-shadow(0 0 5px #ffcc33);
    }

        .btn-custom:hover,
        .btn-custom:focus {
            filter: drop-shadow(0 0 12px #ffcc33);
            transform: scale(1.1) rotate(-2deg);
            box-shadow: 0 12px 25px rgba(255, 204, 51, 0.9);
            outline: none;
        }

    .btn-custom-sm {
        background: linear-gradient(135deg, #ffb347, #ffcc33);
        border: none;
        padding: 10px 28px; /* padding tăng hơn */
        font-size: 20px; /* font-size tăng lên */
        font-weight: 700;
        border-radius: 30px;
        color: #222;
        box-shadow: 0 6px 12px rgba(255, 204, 51, 0.7);
        transition: all 0.3s ease;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        user-select: none;
        filter: drop-shadow(0 0 3px #ffcc33);
    }

        .btn-custom-sm:hover,
        .btn-custom-sm:focus {
            filter: drop-shadow(0 0 8px #ffcc33);
            transform: scale(1.05) rotate(-2deg);
            box-shadow: 0 9px 18px rgba(255, 204, 51, 0.9);
            outline: none;
        }

    /* --- HEADINGS --- */
    h1.display-4,
    h2 {
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 2px;
        text-shadow: 0 0 10px #ffcc33, 0 0 20px #ffa500;
    }

    /* Glow effect for main title */
    h1.display-4 {
        color: #ffc107;
        animation: glow 3s ease-in-out infinite alternate;
    }

    @@keyframes glow {
        from

    {
        text-shadow: 0 0 10px #ffc107, 0 0 20px #ff9800;
    }

    to {
        text-shadow: 0 0 20px #ffea00, 0 0 40px #ff6f00;
    }

    }

    /* --- MAIN CONTENT AREA --- */
    .main-content {
        padding: 50px 20px 80px;
        max-width: 1140px;
        margin: 0 auto;
        background: rgba(0,0,0,0.5);
        border-radius: 20px;
        box-shadow: 0 0 40px rgba(255, 165, 0, 0.5);
    }

    /* --- CARDS --- */
    .card {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(255, 165, 0, 0.4);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background: linear-gradient(135deg, #212121, #414141);
    }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(255, 165, 0, 0.7);
        }

        .card img {
            border-bottom-left-radius: 0;
            border-bottom-right-radius: 0;
            transition: transform 0.4s ease;
        }

        .card:hover img {
            transform: scale(1.05);
        }

        .card:hover::after {
            content: "🔥";
            position: absolute;
            top: 10px;
            right: 15px;
            font-size: 1.5rem;
            animation: bounce 1s infinite;
        }
   @@keyframes bounce {
        0%, 100%

    {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-5px);
    }

    }

    /* --- FEEDBACK BLOCKQUOTE --- */
    .blockquote {
        font-style: italic;
        font-size: 1.1rem;
        border-left: 5px solid #ffb347;
        padding-left: 20px;
        margin-bottom: 30px;
        color: #fff5cc;
        text-shadow: 0 0 6px rgba(255, 179, 71, 0.8);
    }

    /* --- GALLERY IMAGES --- */
    .gallery img {
        border-radius: 15px;
        box-shadow: 0 6px 18px rgba(255, 165, 0, 0.5);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
    }

        .gallery img:hover {
            transform: scale(1.1);
            box-shadow: 0 12px 36px rgba(255, 165, 0, 0.9);
        }

    /* --- PARTNERS --- */
    .partners img {
        filter: brightness(0.8);
        transition: filter 0.3s ease, transform 0.3s ease;
        max-height: 80px;
        margin: 0 auto;
    }

        .partners img:hover {
            filter: brightness(1);
            transform: scale(1.1);
        }

    /* --- FOOTER SOCIAL --- */
    .footer-section {
        color: #eee;
        padding: 40px 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

        .footer-section h4 {
            font-weight: 700;
            margin-bottom: 20px;
            letter-spacing: 1.2px;
            border-bottom: 2px solid #f39c12;
            display: inline-block;
            padding-bottom: 6px;
        }

        .footer-section p,
        .footer-section ul {
            font-size: 0.95rem;
            line-height: 1.6;
        }

        .footer-section ul {
            list-style: none;
            padding-left: 0;
        }

            .footer-section ul li {
                margin-bottom: 10px;
                cursor: pointer;
                transition: color 0.3s ease;
            }

                .footer-section ul li:hover {
                    color: #f39c12;
                }

    .footer-social a {
        color: #eee;
        font-size: 1.5rem;
        margin-right: 15px;
        transition: color 0.3s ease;
    }

        .footer-social a:hover {
            color: #f39c12;
        }
    @@media (max-width: 768px) {
        .footer-section .col-md-4

    {
        margin-bottom: 30px;
        text-align: center;
    }

    }

    /* --- SECTIONS BACKGROUND --- */
    section {
        padding: 60px 15px;
    }

        section.bg-dark {
            background: linear-gradient(135deg, #1a1a1a, #333333);
            box-shadow: inset 0 0 40px rgba(255, 140, 0, 0.3);
        }

    /* --- BUTTON GROUP --- */
    .d-flex.justify-content-center.gap-3 {
        flex-wrap: wrap;
    }

    /* --- FADE IN ANIMATION FOR SECTIONS --- */
    section,
    .main-content > div,
    footer {
        opacity: 0;
        animation: fadeInUp 1s forwards;
        animation-delay: 0.4s;
    }

        section:nth-of-type(2) {
            animation-delay: 0.6s;
        }

        section:nth-of-type(3) {
            animation-delay: 0.8s;
        }

        section:nth-of-type(4) {
            animation-delay: 1s;
        }

        section:nth-of-type(5) {
            animation-delay: 1.2s;
        }

        section:nth-of-type(6) {
            animation-delay: 1.4s;
        }

        section:nth-of-type(7) {
            animation-delay: 1.6s;
        }

    @@keyframes fadeInUp {
        from

    {
        opacity: 0;
        transform: translateY(40px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* --- RESPONSIVE --- */
    @@media (max-width: 767.98px) {
        h1 .display-4

    {
        font-size: 2.4rem;
    }

    .scrolling-text {
        font-size: 1.4rem;
    }

    .btn-custom {
        padding: 12px 28px;
        font-size: 16px;
        gap: 6px;
    }

    .gallery img {
        margin-bottom: 15px;
    }

    }
    /* Tùy chỉnh style cho popup */
    .swal2-popup-custom {
        font-family: 'Poppins', sans-serif;
        border-radius: 15px;
        box-shadow: 0 0 30px #ffcc00;
        background-color: #1a1a1a !important;
    }

    .swal2-title-custom {
        font-weight: 700;
        font-size: 1.8rem;
        color: #ffd700 !important;
    }

    .swal2-html-custom {
        font-size: 1.1rem;
        color: #ffd700 !important;
    }

    .swal2-confirm-custom {
        background: linear-gradient(135deg, #ffb347, #ffcc33) !important;
        color: #222 !important;
        font-weight: 700;
        box-shadow: 0 6px 20px #ffcc33 !important;
    }

        .swal2-confirm-custom:hover {
            filter: drop-shadow(0 0 10px #ffcc33);
        }

    .swal2-cancel-custom {
        background: #555 !important;
        color: #ddd !important;
    }

        .swal2-cancel-custom:hover {
            background: #777 !important;
            color: #fff !important;
        }
    .text-glow {
        text-shadow: 0 0 10px #ffd700, 0 0 20px #ffa500, 0 0 30px #ff8c00;
        animation: glowText 3s ease-in-out infinite alternate;
    }

        @@keyframes glowText {
        from

    {
        text-shadow: 0 0 10px #ffd700;
    }

    to {
        text-shadow: 0 0 20px #ffcc00, 0 0 40px #ff6600;
    }

    }

    .btn-custom-glow {
        background: linear-gradient(135deg, #ffb347, #ffcc33);
        color: #222;
        font-weight: 700;
        padding: 14px 30px;
        font-size: 1.2rem;
        border-radius: 30px;
        border: none;
        box-shadow: 0 8px 20px rgba(255, 204, 51, 0.7);
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-custom-glow:hover {
            transform: scale(1.1) rotate(-2deg);
            box-shadow: 0 12px 30px rgba(255, 204, 51, 0.9);
        }

    .video-slide {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        transition: opacity 1s ease-in-out;
        pointer-events: none;
        z-index: 0;
    }

        .video-slide.active {
            opacity: 1;
            pointer-events: auto;
        }

    /* NEW: video wrapper để phóng lớn chiều cao, cắt phần dư */
    .video-wrapper {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 100%;
        height: 177.78%; /* 16:9 -> 9:16 để full chiều ngang */
        transform: translate(-50%, -50%);
        overflow: hidden;
    }

        .video-wrapper iframe {
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

    .room-item img {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
    }

        .room-item img:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 15px rgba(0, 0, 0, 0.3);
        }

</style>

<!-- Hiệu ứng chạy chữ -->
<div class="scrolling-text-container">
    <div class="scrolling-text">🎶 Chào mừng đến với Zanee's Music Studio! 🎵</div>
</div>
<div class="scrolling-text-container">
