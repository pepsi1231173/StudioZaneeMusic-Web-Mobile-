@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Transition link effect
            const links = document.querySelectorAll(".transition-link");
            links.forEach(link => {
                link.addEventListener("click", function (event) {
                    event.preventDefault();
                    let href = this.href;
                    document.body.classList.add("fade-out", "active");
                    setTimeout(() => {
                        window.location.href = href;
                    }, 500);
                });
            });
        });
    </script>

    <!-- TAWK.TO LIVE CHAT -->
    <script type="text/javascript">
        var Tawk_API = Tawk_API || {}, Tawk_LoadStart = new Date();
        (function () {
            var s1 = document.createElement("script"), s0 = document.getElementsByTagName("script")[0];
            s1.async = true;
            s1.src = 'https://embed.tawk.to/YOUR_PROPERTY_ID/default';
            s1.charset = 'UTF-8';
            s1.setAttribute('crossorigin', '*');
            s0.parentNode.insertBefore(s1, s0);
        })();
    </script>
    <!-- Hidden input lưu trạng thái đăng nhập -->
    <input type="hidden" id="isLoggedIn" value="@(!string.IsNullOrEmpty(HttpContextAccessor.HttpContext.Session.GetString("username")))" />

    <script>
        function checkLoginSweet() {
            const isLoggedIn = document.getElementById('isLoggedIn').value === 'True';

            if (!isLoggedIn) {
                Swal.fire({
                    title: '<span><i class="fa-solid fa-music"></i> Cần đăng nhập!</span>',
                    html: '<p>🎵 Bạn phải đăng nhập để sử dụng dịch vụ tại Zanee’s Music Studio.</p>',
                    icon: 'warning',
                    background: '#1a1a1a',
                    color: '#ffd700',
                    showCancelButton: true,
                    confirmButtonText: 'Đi đến đăng nhập',
                    cancelButtonText: 'Hủy',
                    confirmButtonColor: '#ffcc00',
                    cancelButtonColor: '#555',
                    customClass: {
                        popup: 'swal2-popup-custom',
                        title: 'swal2-title-custom',
                        htmlContainer: 'swal2-html-custom',
                        confirmButton: 'swal2-confirm-custom',
                        cancelButton: 'swal2-cancel-custom'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        window.location.href = "/Identity/Account/Login";
                    }
                });
                return false; // Ngăn link mặc định
            }

            // Nếu đã đăng nhập, bạn có thể redirect hoặc làm gì đó
            return true;
        }
    </script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const slides = document.querySelectorAll("#videoSlider .video-slide");
            let current = 0;

            setInterval(() => {
                slides[current].classList.remove("active");
                current = (current + 1) % slides.length;
                slides[current].classList.add("active");
            }, 10000); // chuyển mỗi 10s
        });
    </script>

}

