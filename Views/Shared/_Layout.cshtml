@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var username = HttpContextAccessor.HttpContext.Session.GetString("username");
    var email = HttpContextAccessor.HttpContext.Session.GetString("email");
    var role = HttpContextAccessor.HttpContext.Session.GetString("role");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Zanee's Music Studio</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Lobster&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        /* Reset cơ bản */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-image: url('/ProjectStudio/public/images/background.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: white;
            text-align: center;
        }

        nav.navbar, .navbar-brand, .navbar-nav .nav-link {
            font-family: 'Lobster', cursive !important;
        }

        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            padding: 0;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .navbar-brand {
            text-transform: uppercase;
            font-size: 2rem;
            font-weight: bold;
            color: white !important;
        }

        .container {
            max-width: 850px;
            margin-top: 20px;
            padding-top: 50px;
            padding-bottom: 50px;
        }

        .custom-navbar {
            background-color: transparent;
        }

        .btn-custom {
            border-radius: 10px;
            font-weight: bold;
            font-size: 18px;
            padding: 15px 25px;
            width: 100%;
            transition: all 0.3s ease-in-out;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: linear-gradient(135deg,rgb(196, 125, 43),rgb(199, 125, 30));
            border: none;
            color: white;
            box-shadow: 0px 4px 10px rgba(255, 195, 117, 0.3);
            margin-bottom: 200px;
            margin-top: 30px;
        }

            .btn-custom i {
                font-size: 20px;
            }

            .btn-custom:hover {
                transform: scale(1.05);
                filter: brightness(1.2);
                box-shadow: 0px 6px 15px rgba(214, 127, 51, 0.5);
            }

        .d-grid {
            gap: 15px;
        }

        .navbar-nav .nav-link {
            font-size: 1.2rem;
            font-weight: 500;
            margin-left: 15px;
            margin-right: 15px;
            color: white !important;
            transition: color 0.3s ease;
        }

            .navbar-nav .nav-link:hover {
                color: #ffcc70 !important;
                text-decoration: underline;
            }

        .footer-container {
            width: 1000px;
            max-width: 1400px;
            margin: auto;
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            text-align: left;
        }

        /* Hiệu ứng mờ dần khi chuyển trang */
        .fade-out {
            opacity: 1;
            transition: opacity 0.5s ease-in-out;
        }

            .fade-out.active {
                opacity: 0;
            }

        .studio-title {
            font-size: 2rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        /* Loading Intro */
        #intro-loading {
            display: none; /* Ẩn mặc định */
            position: fixed;
            inset: 0;
            background-color: black;
            display: flex;
            justify-content: center;
            align-items: center;
            user-select: none;
            z-index: 9999;
            font-size: 5rem;
            font-weight: 700;
            font-family: 'Brush Script MT', cursive, 'Segoe UI', sans-serif;
            letter-spacing: 2px;
            opacity: 1;
            transition: opacity 0.8s ease;
            flex-direction: column;
        }

            #intro-loading.active {
                display: flex; /* Khi active mới hiện */
            }

            #intro-loading.fade-out {
                opacity: 0;
                pointer-events: none;
            }

        #intro-subtext {
            font-size: 0.7rem;
            font-weight: normal;
            margin-top: 10px;
            color: #666;
            letter-spacing: normal;
        }

        #main-content {
            display: none;
            padding: 20px;
            opacity: 0;
            transition: opacity 1s ease;
        }

            #main-content.fade-in {
                display: block;
                opacity: 1;
            }

        /* Loading bar style */
        .loading-bar {
            width: 120px;
            height: 4px;
            background: rgba(255, 255, 255, 0.2);
            overflow: hidden;
            position: relative;
            border-radius: 2px;
            margin: 20px auto 0;
            box-shadow: 0 0 8px rgba(255, 255, 255, 0.15);
        }

            .loading-bar::after {
                content: "";
                position: absolute;
                left: -40%;
                top: 0;
                width: 40%;
                height: 100%;
                background: white;
                border-radius: 2px;
                animation: loadingAnim 4s linear infinite;
                box-shadow: 0 0 8px white;
            }

        @@keyframes loadingAnim {
            0%

        {
            left: -40%;
        }

        100% {
            left: 100%;
        }

        }

        #intro-loading > div {
            opacity: 0;
            animation: fadeInOut 4s ease forwards;
        }

        @@keyframes fadeInOut {
            0%

        {
            opacity: 0;
        }

        25% {
            opacity: 1;
        }

        75% {
            opacity: 1;
        }

        100% {
            opacity: 0;
        }

        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    @await Html.PartialAsync("_IntroLoading")

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark custom-navbar">
        <div class="container-fluid">
            <a id="brandLink" class="navbar-brand studio-title d-flex align-items-center fw-bold text-white" href="/" style="font-size: 2rem;">
                <i class="fas fa-music me-2"></i> ZANEE'S MUSIC STUDIO
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">🏠 Trang chủ</a></li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="servicesDropdown" data-bs-toggle="dropdown">
                            🎼 Dịch vụ
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark">
                            <li><a class="dropdown-item" href="/Services/Recording">🎧 Thu âm</a></li>
                            <li><a class="dropdown-item" href="/Services/Studio">🎹 Thuê phòng</a></li>
                            <li><a class="dropdown-item" href="/Services/Instruments">🎸 Nhạc cụ</a></li>
                            <li><a class="dropdown-item" href="/Services/Instruments">🎵 Làm nhạc</a></li>
                        </ul>
                    </li>
                    <li class="nav-item"><a class="nav-link" href="/Blog">📰 Tin tức</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Contact">📞 Liên hệ</a></li>
                    <li class="nav-item"><a class="nav-link" href="/About">📖 Giới thiệu</a></li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-outline-light fw-bold px-3 py-1 me-2" href="/Identity/Account/Register">
                            📝 Đăng ký
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-outline-light fw-bold px-3 py-1 me-2" href="/Identity/Account/Login">
                            🔐 Đăng nhập
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Nội dung chính -->
    <div id="main-content" class="container my-4">
        @RenderBody()
    </div>

    <!-- Modal cập nhật tài khoản -->
    @if (!string.IsNullOrEmpty(username))
    {
        <div class="modal fade" id="editUserModal" tabindex="-1" aria-labelledby="editUserModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content p-4">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold">Cập nhật tài khoản</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                    </div>
                    <form asp-controller="User" asp-action="EditAccount" method="post">
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label">Tên đăng nhập</label>
                                <input type="text" class="form-control" name="Username" value="@username" required />
                            </div>
                            <div class="form-group position-relative">
                                <label class="form-label">Mật khẩu hiện tại</label>
                                <input type="password" class="form-control" name="CurrentPassword" id="current_password" required />
                                <i class="bi bi-eye password-toggle" onclick="togglePassword('current_password')"></i>
                            </div>
                            <div class="form-group position-relative">
                                <label class="form-label">Mật khẩu mới</label>
                                <input type="password" class="form-control" name="NewPassword" id="new_password" />
                                <i class="bi bi-eye password-toggle" onclick="togglePassword('new_password')"></i>
                            </div>
                            <div class="form-group position-relative">
                                <label class="form-label">Xác nhận mật khẩu mới</label>
                                <input type="password" class="form-control" name="ConfirmPassword" id="confirm_password" />
                                <i class="bi bi-eye password-toggle" onclick="togglePassword('confirm_password')"></i>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" name="Email" value="@email" required />
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="submit" class="btn btn-primary w-100">💾 Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePassword(fieldId) {
            const input = document.getElementById(fieldId);
            const icon = input.nextElementSibling;
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            }
        }

        window.addEventListener('load', () => {
            const intro = document.getElementById('intro-loading');
            const mainContent = document.getElementById('main-content');

            if (!sessionStorage.getItem('introShown')) {
                intro.classList.add('active');

                setTimeout(() => {
                    intro.classList.add('fade-out');
                    setTimeout(() => {
                        intro.style.display = 'none';
                        mainContent.classList.add('fade-in');
                        sessionStorage.setItem('introShown', 'true');
                    }, 1000);
                }, 4000);
            } else {
                intro.style.display = 'none';
                mainContent.classList.add('fade-in');
            }
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
