     <style>
    #intro-loading {
        display: none; /* Ẩn mặc định */
        position: fixed;
        inset: 0;
        background: url('/images/rooms/micro.jpg') no-repeat center center;
        background-size: cover; /* Cho ảnh full màn hình */
        display: flex;
        justify-content: center;
        align-items: center;
        user-select: none;
        z-index: 9999;
        font-size: 5rem;
        font-weight: 700;
        font-family: 'Brush Script MT', cursive, 'Segoe UI', sans-serif;
        letter-spacing: 2px;
        opacity: 1;
        transition: opacity 0.8s ease;
        flex-direction: column;
        color: white; /* chữ sáng lên cho dễ nhìn */
        text-shadow: 0 0 12px rgba(0,0,0,0.7); /* đổ bóng chữ */
    }

        #intro-loading::before {
            content: "";
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.5); /* lớp phủ tối 50% */
            z-index: -1; /* để nằm sau text */
        }


            #intro-loading.active {
                display: flex; /* Khi active mới hiện */
            }

            #intro-loading.fade-out {
                opacity: 0;
                pointer-events: none;
            }

        #intro-subtext {
            font-size: 0.7rem;
            font-weight: normal;
            margin-top: 10px;
            color: #666;
            letter-spacing: normal;
        }

        #main-content {
            display: none;
            padding: 20px;
            opacity: 0;
            transition: opacity 1s ease;
        }

            #main-content.fade-in {
                display: block;
                opacity: 1;
            }

        /* Loading bar style */
        .loading-bar {
            width: 120px;
            height: 4px;
            background: rgba(255, 255, 255, 0.2);
            overflow: hidden;
            position: relative;
            border-radius: 2px;
            margin: 20px auto 0;
            box-shadow: 0 0 8px rgba(255, 255, 255, 0.15);
        }

            .loading-bar::after {
                content: "";
                position: absolute;
                left: -40%;
                top: 0;
                width: 40%;
                height: 100%;
                background: white;
                border-radius: 2px;
                animation: loadingAnim 2s linear infinite;
                box-shadow: 0 0 8px white;
            }

        @@keyframes loadingAnim {
            0%

        {
            left: -40%;
        }

        100% {
            left: 100%;
        }

        }

        #intro-loading > div {
            opacity: 0;
            animation: fadeInOut 4s ease forwards;
        }

        @@keyframes fadeInOut {
            0%

        {
            opacity: 0;
        }

        25% {
            opacity: 1;
        }

        75% {
            opacity: 1;
        }

        100% {
            opacity: 0;
        }

        }

    </style>
<div id="intro-loading" aria-label="Loading">
    <div>
        ZANEE'S MUSIC STUDIO
        <div id="intro-subtext">Nơi âm nhạc thăng hoa cùng bạn</div>
        <div class="loading-bar"></div>
    </div>
</div>
<script>
    window.addEventListener('load', () => {
           const intro = document.getElementById('intro-loading');
           const mainContent = document.getElementById('main-content');

           // Lấy thông tin user hiện tại từ server render ra (hoặc localStorage/sessionStorage)
           const currentUser = "@User.Identity.Name"; // Razor, nếu bạn dùng ASP.NET
           const introKey = "introShown_" + currentUser;

           // Kiểm tra flag xem có cần chạy intro hay không
           if (sessionStorage.getItem("forceIntro") === "true" || !sessionStorage.getItem(introKey)) {
               intro.classList.add('active');

               setTimeout(() => {
                   intro.classList.add('fade-out');
                   setTimeout(() => {
                       intro.style.display = 'none';
                       mainContent.classList.add('fade-in');

                       // Lưu lại là đã chạy intro cho user này
                       sessionStorage.setItem(introKey, 'true');
                       sessionStorage.removeItem("forceIntro"); // Xóa flag
                   }, 1000);
               }, 4000); // Thời gian intro
           } else {
               intro.style.display = 'none';
               mainContent.classList.add('fade-in');
           }
       });
</script>