@model List<IGrouping<DateTime, DuAnBai3.Models.Booking>>
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery AntiForgery
@{
    ViewData["Title"] = "Quản lý đơn đặt phòng";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";

    var token = AntiForgery.GetAndStoreTokens(Context).RequestToken;
    var approveUrl = Url.Action("Approve", "Booking", new { area = "Admin" });
    var cancelUrl = Url.Action("Cancel", "Booking", new { area = "Admin" });
    var maintenanceUrl = Url.Action("Maintenance", "Booking", new { area = "Admin" });
}

<input type="hidden" id="__RequestVerificationToken" value="@token" />
<input type="hidden" id="approveUrl" value="@approveUrl" />
<input type="hidden" id="cancelUrl" value="@cancelUrl" />
<input type="hidden" id="maintenanceUrl" value="@maintenanceUrl" />

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />

<style>
    body {
        background: url('/images/background.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Poppins', sans-serif;
    }

    html, body {
        overflow-x: hidden !important;
    }

    .booking-card {
        background: #fff;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,.1);
        border-left: 6px solid transparent;
    }

        .booking-card.pending {
            border-color: #ffc107;
        }

        .booking-card.booked {
            border-color: #dc3545;
        }

        .booking-card.available {
            border-color: #28a745;
        }

        .booking-card.active {
            border-color: #fd7e14;
        }

        .booking-card.completed {
            border-color: #6c757d;
        }

        .booking-card.cancelled {
            border-color: #8B4513; /* Nâu */
        }

    .status {
        font-weight: bold;
        padding: 4px 10px;
        border-radius: 8px;
    }

        .status.pending {
            background: #ffc107;
            color: #000;
        }

        .status.booked {
            background: #dc3545;
            color: #fff;
        }

        .status.available {
            background: #28a745;
            color: #fff;
        }

        .status.active {
            background: #fd7e14;
            color: #fff;
        }

        .status.completed {
            background: #6c757d;
            color: #fff;
        }
    .status.cancelled {
        background: #8B4513; /* Nâu */
        color: #fff;
    }

    .btn-outline-purple {
        border: 1px solid #6f42c1;
        color: #6f42c1;
    }

        .btn-outline-purple:hover {
            background: #6f42c1;
            color: #fff;
        }

    #timeDisplay {
        color: #fff;
        font-weight: 700;
        font-size: 1.3rem;
        text-shadow: 0 0 8px rgba(255,255,255,.7);
    }

    #toast-container-left, #toast-container-right {
        position: fixed;
        top: 60px;
        z-index: 9999;
    }

    #toast-container-left {
        left: 20px;
    }

    #toast-container-right {
        right: 20px;
    }

    .toast {
        min-width: 350px;
        font-size: 1.4rem;
        padding: 20px 30px;
        border-radius: 12px;
        display: none;
    }
</style>
<div class="container mt-5">
    <h2 class="text-center mb-4 text-white">📋 Danh sách các đơn đặt phòng tập</h2>
    <div class="row mb-3">
        <label class="col-sm-2 col-form-label text-white fw-bold" for="filterDate">Lọc theo ngày:</label>
        <div class="col-sm-4">
            <input type="date" id="filterDate" class="form-control" />
        </div>
        <div class="col-sm-6 text-end">
            <span id="timeDisplay"></span>
        </div>
    </div>
    <div id="noBookingsWarning" class="alert alert-warning text-center" style="@(Model.Any() ? "display:none;" : "")">
        Không có đơn đặt phòng nào!
    </div>
    <div id="booking-list">
        @if (Model.Any())
        {
            foreach (var dayGroup in Model.OrderBy(g => g.Key))
            {
                var dateStr = dayGroup.Key.Date.ToString("dd/MM/yyyy");
                var dateAttr = dayGroup.Key.Date.ToString("yyyy-MM-dd");
                <h4 class="text-white mt-4" data-date="@dateAttr">📅 @dateStr</h4>
                foreach (var b in dayGroup)
                {
                    var cls = b.Status switch
                    {
                        "pending" => "pending",
                        "booked" or "Đã đặt" => "booked",
                        "active" => "active",
                        "completed" => "completed",
                        "cancelled" or "Đã hủy" => "cancelled",
                        _ => "available"
                    };

                    var text = b.Status switch
                    {
                        "pending" => "Chờ duyệt",
                        "booked" or "Đã đặt" => "Đã đặt",
                        "active" => "Đang sử dụng",
                        "completed" => "Hoàn tất",
                        "cancelled" or "Đã hủy" => "Đã hủy",
                        _ => "Chưa đặt"
                    };

                    var endTime = b.StartTime.Add(TimeSpan.FromHours(b.RentalDuration));
                    <div class="booking-card @cls" id="card-@b.Id" data-date="@dateAttr">
                        <div class="row gy-2 gx-3">
                            <div class="col-md-6">
                                <p><strong>Mã đơn:</strong> #@b.DailyBookingNumber.ToString("D4")</p>
                                <p><strong>Phòng:</strong> @b.RoomId</p>
                                <p><strong>Khách hàng:</strong> @b.CustomerName</p>
                                <p><strong>Ngày thuê:</strong> @dateStr</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Thời lượng:</strong> @b.RentalDuration giờ</p>
                                <p><strong>Giờ bắt đầu:</strong> @DateTime.Today.Add(b.StartTime).ToString("HH:mm")</p>
                                <p><strong>Giờ kết thúc:</strong> @DateTime.Today.Add(endTime).ToString("HH:mm")</p>
                                <p><strong>Đơn giá:</strong> @b.Price.ToString("#,0", System.Globalization.CultureInfo.InvariantCulture).Replace(",", ".") VNĐ</p>
                                <p><strong>Trạng thái:</strong> <span class="status @cls" id="status-@b.Id">@text</span></p>
                            </div>
                            <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                                @if (cls == "cancelled")
                                {
                                    <button class="btn btn-dark btn-sm" onclick="deleteBooking('@b.DailyBookingNumber','@dateAttr')">🗑 Xóa</button>
                                }
                                else
                                {
                                    <button class="btn btn-success btn-sm" onclick="approveBooking('@b.DailyBookingNumber','@dateAttr')">✅ Duyệt</button>
                                    <button class="btn btn-warning btn-sm" onclick="cancelBooking('@b.DailyBookingNumber','@dateAttr')">❌ Hủy</button>
                                    <button class="btn btn-dark btn-sm" onclick="deleteBooking('@b.DailyBookingNumber','@dateAttr')">🗑 Xóa</button>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        }
    </div>
    <div class="row mt-4">
        <div class="col-md-3 mb-3"><a asp-action="History" class="btn btn-outline-purple w-100">📂 Xem lịch sử đơn</a></div>
        <div class="col-md-3 mb-3"><button id="btnMaintenance" class="btn btn-outline-secondary w-100">🔧 BẢO TRÌ</button></div>
    </div>
    <a href="/Admin/Homepage/Dashboard" class="btn btn-secondary mt-4">🔙 Quay lại</a>
</div>

<!-- Modal chọn phòng bảo trì -->
<div class="modal fade" id="maintenanceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 shadow">
            <div class="modal-header">
                <h5 class="modal-title">Chọn phòng để bảo trì</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <form id="maintenanceForm">
                    @foreach (var room in new[] { "A", "B", "C" })
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" value="@room" id="room@room" />
                            <label class="form-check-label" for="room@room">Phòng @room</label>
                        </div>
                    }
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="confirmMaintenance">Xác nhận</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <div id="toast-container-left"></div>
    <div id="toast-container-right"></div>

    <script>
        function showToast(containerId, msg, bg = "bg-info", delay = 3000) {
            const t = $(`<div class="toast ${bg} text-white mb-2" role="alert">${msg}</div>`);
            $(`#${containerId}`).append(t);
            t.fadeIn(200).delay(delay).fadeOut(400, () => t.remove());
        }

        $('#filterDate').on('input', applyDateFilter);
        function applyDateFilter() {
            const val = $('#filterDate').val();
            if (!val) {
                $('[data-date]').show();
            } else {
                $('[data-date]').hide();
                $(`[data-date="${val}"]`).show();
            }
            $('#noBookingsWarning').toggle(!$('.booking-card:visible').length);
        }

        function tick() {
            $('#timeDisplay').text(new Date().toLocaleString('vi-VN', {
                hour: '2-digit', minute: '2-digit', second: '2-digit',
                day: '2-digit', month: '2-digit', year: 'numeric', hour12: false
            }));
        }
        tick();
        setInterval(tick, 1000);

        const connection = new signalR.HubConnectionBuilder().withUrl("/bookingHub").build();
        const connectionReady = connection.start()
            .then(() => console.log("✔️ SignalR connected"))
            .catch(err => console.error("❌ SignalR error:", err));

        connection.on("BookingStatusChanged", (id, roomId, rentalDate, startTime, duration, status) => {
            const card = document.getElementById(`card-${id}`);
            const cleanStatus = status?.trim().toLowerCase();

            if (!card) return;

                  if (cleanStatus === "cancelled") {
            const statusElement = card.querySelector(".status");
            if (statusElement) {
                statusElement.textContent = "Đã hủy";
                statusElement.className = "status cancelled";
            }

            card.className = "booking-card cancelled";

            // Chỉ giữ nút Xóa, remove các nút khác
            const buttons = card.querySelectorAll("div.col-12 button");
            buttons.forEach(btn => {
                if (!btn.textContent.includes("Xóa")) btn.remove();
            });

            return;
        }

                const map = {
            pending: "pending",
            booked: "booked",
            active: "active",
            completed: "completed",
            cancelled: "cancelled"
        };

        const textMap = {
            pending: "Chờ duyệt",
            booked: "Đã đặt",
            active: "Đang sử dụng",
            completed: "Hoàn tất",
            cancelled: "Đã hủy"
        };


            const cls = map[cleanStatus] ?? "available";
            const text = textMap[cleanStatus] ?? "Không xác định";

            $(`#status-${id}`).text(text).attr("class", "status " + cls);
            $(card).attr("class", "booking-card " + cls);
        });

        connection.on("MaintenanceUpdated", rooms => {
            // Optional UI update
        });

        connection.on("BookingCreated", (b) => {
            renderBookingCard(b);
            applyDateFilter();
            showToast("toast-container-left",
                `🆕 Có đơn đặt mới từ ${b.customerName} - Phòng ${b.roomId}`,
                "bg-primary");
        });

        const approveUrl = document.getElementById("approveUrl").value;
        const cancelUrl = document.getElementById("cancelUrl").value;
        const maintenanceUrl = document.getElementById("maintenanceUrl").value;

        async function approveBooking(no, date) {
            if (!confirm(`Duyệt đơn #${no.padStart(4, '0')}?`)) return;
            await connectionReady;
            const token = $('#__RequestVerificationToken').val();
            const res = await fetch(approveUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ DailyNumber: +no, RentalDate: date })
            });
            if (res.ok) {
                showToast("toast-container-right", "✅ Duyệt thành công", "bg-success");
            } else {
                showToast("toast-container-right", "❌ Lỗi duyệt", "bg-danger");
            }
        }

        async function cancelBooking(no, date) {
            if (!confirm(`Hủy đơn #${no.padStart(4, '0')}?`)) return;
            await connectionReady;
            const token = $('#__RequestVerificationToken').val();
            const res = await fetch(cancelUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ DailyNumber: +no, RentalDate: date })
            });
            if (res.ok) {
                showToast("toast-container-right", "🗑️ Hủy thành công", "bg-warning");
            } else {
                showToast("toast-container-right", "❌ Lỗi hủy", "bg-danger");
            }
        }
                connection.on("BookingDeleted", (id, date) => {
            const card = document.getElementById(`card-${id}`);
            if (card) $(card).fadeOut(300, function() { $(this).remove(); });

            // Nếu không còn booking nào trong ngày, xóa tiêu đề ngày
            if ($(`[data-date='${date}'] .booking-card`).length === 0) {
                $(`h4[data-date='${date}']`).remove();
            }
        });

         async function deleteBooking(no, date) {
            if (!confirm(`Xóa vĩnh viễn đơn #${no.padStart(4,'0')}?`)) return;
            await connectionReady;

            const token = $('#__RequestVerificationToken').val();
            const res = await fetch('@Url.Action("Delete", "Booking", new { area = "Admin" })', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ DailyNumber: +no, RentalDate: date })
            });

            if (res.ok) {
                showToast("toast-container-right", "🗑️ Xóa thành công", "bg-danger");
            } else {
                showToast("toast-container-right", "❌ Lỗi xóa", "bg-danger");
            }
        }

        const maintenanceModal = new bootstrap.Modal('#maintenanceModal');
        let roomsBeforeUpdate = [];

        async function loadMaintenanceStatus() {
            const res = await fetch(maintenanceUrl);
            if (res.ok) {
                roomsBeforeUpdate = await res.json();
                $('#maintenanceForm input[type=checkbox]').each(function () {
                    $(this).prop('checked', roomsBeforeUpdate.includes(this.value));
                });
            }
        }

        $('#btnMaintenance').on('click', () => {
            loadMaintenanceStatus();
            maintenanceModal.show();
        });

        $('#confirmMaintenance').on('click', async () => {
            const token = $('#__RequestVerificationToken').val();
            const rooms = [...$('#maintenanceForm input:checked')].map(cb => cb.value);
            await connectionReady;

            const res = await fetch(maintenanceUrl, {
                method: "POST",
                headers: {
                    'Content-Type': "application/json",
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ rooms })
            });

            if (res.ok) {
                const updatedRooms = await res.json();
                maintenanceModal.hide();

                const turnedOn = updatedRooms.filter(r => !roomsBeforeUpdate.includes(r));
                const turnedOff = roomsBeforeUpdate.filter(r => !updatedRooms.includes(r));

                let msgParts = [];
                if (turnedOn.length > 0) msgParts.push(`🔧 Đã chuyển sang bảo trì: ${turnedOn.join(', ')}`);
                if (turnedOff.length > 0) msgParts.push(`✅ Đã tắt bảo trì phòng: ${turnedOff.join(', ')}`);

                const msg = msgParts.length > 0 ? msgParts.join(' | ') : "✅ Không có thay đổi trạng thái bảo trì.";
                showToast("toast-container-right", msg, "bg-secondary");

                roomsBeforeUpdate = updatedRooms;
            } else {
                const err = await res.json();
                const msg = err.message + ' ' + (err.rooms?.join(', ') ?? '');
                showToast("toast-container-right", `❌ ${msg}`, "bg-danger", 6000);
            }
        });

        function formatDateVN(dateString) {
            const d = new Date(dateString);
            const day = String(d.getDate()).padStart(2, '0');
            const month = String(d.getMonth() + 1).padStart(2, '0');
            const year = d.getFullYear();
            return `${day}/${month}/${year}`;
        }

        function renderBookingCard(b) {
            const dateAttr = new Date(b.rentalDate).toISOString().slice(0, 10);
            const dateStr = formatDateVN(b.rentalDate);
           const cls = {
            pending: 'pending',
            booked: 'booked',
            active: 'active',
            completed: 'completed',
            cancelled: 'cancelled' // thêm
        }[b.status] ?? 'available';

        const text = {
            pending: 'Chờ duyệt',
            booked: 'Đã đặt',
            active: 'Đang sử dụng',
            completed: 'Hoàn tất',
            cancelled: 'Đã hủy' // thêm
        }[b.status] ?? 'Chưa đặt';


            const start = b.startTime;

            function addHoursToTime(timeStr, hours) {
                const [h, m] = timeStr.split(':').map(Number);
                const d = new Date();
                d.setHours(h);
                d.setMinutes(m);
                d.setSeconds(0);
                d.setMilliseconds(0);
                d.setTime(d.getTime() + hours * 3600000);
                return d.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit', hour12: false });
            }

            const end = addHoursToTime(start, b.rentalDuration);

            function formatPrice(number) {
                return number.toLocaleString('vi-VN');
            }

            if (!$(`[data-date='${dateAttr}']`).length) {
                $('#booking-list').append(`<h4 class="text-white mt-4" data-date="${dateAttr}">📅 ${dateStr}</h4>`);
            }

            const html = `
                <div class="booking-card ${cls}" id="card-${b.id}" data-date="${dateAttr}">
                    <div class="row gy-2 gx-3">
                        <div class="col-md-6">
                            <p><strong>Mã đơn:</strong> #${String(b.dailyBookingNumber).padStart(4, '0')}</p>
                            <p><strong>Phòng:</strong> ${b.roomId}</p>
                            <p><strong>Khách hàng:</strong> ${b.customerName}</p>
                            <p><strong>Ngày thuê:</strong> ${dateStr}</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Thời lượng:</strong> ${b.rentalDuration} giờ</p>
                            <p><strong>Giờ bắt đầu:</strong> ${start}</p>
                            <p><strong>Giờ kết thúc:</strong> ${end}</p>
                            <p><strong>Đơn giá:</strong> ${formatPrice(b.price)} VNĐ</p>
                            <p><strong>Trạng thái:</strong> <span class="status ${cls}" id="status-${b.id}">${text}</span></p>
                        </div>
                        <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                                <button class="btn btn-success btn-sm" onclick="approveBooking('${b.dailyBookingNumber}', '${dateAttr}')">✅ Duyệt</button>
                                <button class="btn btn-danger btn-sm" onclick="cancelBooking('${b.dailyBookingNumber}', '${dateAttr}')">❌ Hủy</button>
                                <button class="btn btn-dark btn-sm" onclick="deleteBooking('${b.dailyBookingNumber}', '${dateAttr}')">🗑 Xóa</button>
                        </div>
                    </div>
                </div>`;

            $(`[data-date="${dateAttr}"]:last`).after(html);
        }

        // Tiện ích tính giờ
        function addHoursToTime(timeStr, hours) {
            const [h, m] = timeStr.split(':').map(Number);
            const d = new Date();
            d.setHours(h);
            d.setMinutes(m);
            d.setSeconds(0);
            d.setMilliseconds(0);
            d.setTime(d.getTime() + hours * 3600000);
            return d.toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit', hour12: false });
        }

        function formatPrice(number) {
            return number.toLocaleString('vi-VN');
        }

    </script>
}
