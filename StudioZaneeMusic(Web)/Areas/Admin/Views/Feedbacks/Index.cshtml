@model List<DuAnBai3.Models.Feedback>

@{
    ViewData["Title"] = "Quản lý Feedback";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .neon-text {
        font-family: 'Lobster', cursive;
        font-size: 36px;
        font-weight: 900;
        color: #ffd700;
        text-shadow: 0 0 3px rgba(255, 215, 0, 0.7), 0 0 6px rgba(255, 215, 0, 0.5), 0 0 10px rgba(255, 204, 0, 0.4), 0 0 15px rgba(248, 210, 16, 0.3);
    }

    .feedback-card {
        border-radius: 12px;
        box-shadow: 0 0 10px rgba(0,0,0,0.15);
        transition: 0.3s;
    }

        .feedback-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 20px rgba(0,0,0,0.25);
        }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>

<div class="container mt-4">
    <h1 class="mb-4 text-center">
        <span class="neon-text">@ViewData["Title"]</span>
    </h1>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var f in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card feedback-card @(f.IsNew ? "border-warning" : "")">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="fas fa-user"></i> @f.Name
                            </h5>
                            <p class="card-text mb-1"><strong>Email:</strong> @f.Email</p>
                            <p class="card-text mb-1"><strong>Phone:</strong> @f.Phone</p>
                            <p class="card-text mb-1">
                                <strong>Rating:</strong>
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= f.Rating)
                                    {
                                        <i class="fas fa-star" style="color: gold;"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-star" style="color: gray;"></i>
                                    }
                                }
                            </p>
                            <p class="card-text"><strong>Message:</strong> @f.Message</p>
                            <p class="card-text text-muted small">
                                <i class="fas fa-clock"></i> @f.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")
                            </p>
                            <p class="card-text">
                                <span class="badge @(f.IsNew ? "bg-warning text-dark" : "bg-secondary")">
                                    @(f.IsNew ? "Mới" : "Đã xem")
                                </span>
                            </p>

                            <!-- Form xóa -->
                            <form asp-area="Admin" asp-controller="Feedbacks" asp-action="Delete" method="post" onsubmit="return confirmDelete(this);">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@f.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i> Xóa
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            Không có feedback nào
        </div>
    }
</div>

<script>
    // Dùng SweetAlert để confirm trước khi submit form
    async function confirmDelete(form) {
        const result = await Swal.fire({
            title: 'Bạn có chắc muốn xóa phản hồi này?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Xóa',
            cancelButtonText: 'Hủy'
        });

        if (result.isConfirmed) {
            form.submit();
        }
        return false;
    }
</script>
