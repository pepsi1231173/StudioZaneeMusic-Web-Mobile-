@model List<DuAnBai3.Areas.Admin.Controllers.InstrumentRentalViewModel>

@{
    ViewData["Title"] = "Danh Sách Đơn Thuê Nhạc Cụ";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var allProducts = ViewBag.AllProducts as List<DuAnBai3.Models.Product>;
    var rentedIds = ViewBag.RentedInstrumentIds as List<int> ?? new List<int>();
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: url('/images/background.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Poppins', sans-serif;
    }

    html, body {
        overflow-x: hidden !important;
    }

    .rental-card {
        background: #2d2d44;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        border-left: 6px solid #0dcaf0;
        color: white;
    }

    .instrument-item img {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 8px;
        margin-right: 8px;
    }

    .instrument-item {
        display: flex;
        align-items: center;
        margin-bottom: 5px;
    }
</style>

<div class="container mt-5">
    <h2 class="text-center mb-4 text-white">🎸 Danh sách đơn thuê nhạc cụ</h2>

    <!-- Nút Bảo trì nhạc cụ riêng -->
    <button class="btn btn-warning mb-4" data-bs-toggle="modal" data-bs-target="#maintenanceModal">
        🛠 Bảo trì nhạc cụ
    </button>

    @if (Model.Any())
    {
        foreach (var item in Model)
        {
            var rental = item.Rental;
            var instruments = item.InstrumentNames;
            var images = item.InstrumentImages;

            <div class="rental-card">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Mã đơn:</strong> #@rental.Id</p>
                        <p><strong>Tên khách:</strong> @rental.CustomerName</p>
                        <p><strong>Ngày thuê:</strong> @(rental.RentalDate?.ToString("dd/MM/yyyy") ?? "Chưa rõ")</p>
                        <p>
                            <strong>Trạng thái đơn:</strong>
                            @if (rental.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                            }
                            else if (rental.Status == "Confirmed")
                            {
                                <span class="badge bg-success">Đã xác nhận</span>
                            }
                            else if (rental.Status == "Completed")
                            {
                                <span class="badge bg-primary">Đã hoàn tất</span>
                            }
                            else if (rental.Status == "Cancelled")
                            {
                                <span class="badge bg-danger">Đã hủy</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@rental.Status</span>
                            }
                        </p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Số điện thoại:</strong> @rental.CustomerPhone</p>

                        <p><strong>Danh sách nhạc cụ:</strong></p>
                        @if (instruments.Any())
                        {
                            <div>
                                @for (int i = 0; i < instruments.Count; i++)
                                {
                                    <div class="instrument-item">
                                        <img src="@images[i]" alt="@instruments[i]" />
                                        <span>@instruments[i]</span>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p>Không có nhạc cụ nào</p>
                        }

                        <p><strong>Tổng tiền:</strong> @(rental.TotalPrice?.ToString("N0") ?? "0") VNĐ</p>

                        <div class="d-flex justify-content-end mt-3">
                            <div class="btn-group" role="group">
                                @if (rental.Status == "Pending")
                                {
                                    <form asp-action="Confirm" method="post" class="me-2"
                                          onsubmit="return confirm('Bạn có chắc muốn xác nhận đơn này không?')">
                                        <input type="hidden" name="rentalId" value="@rental.Id" />
                                        <button type="submit" class="btn btn-success">
                                            ✅ Xác nhận
                                        </button>
                                    </form>
                                }

                                @if (rental.Status == "Confirmed")
                                {
                                    <form asp-action="CompleteRental" method="post" class="me-2"
                                          onsubmit="return confirm('Xác nhận khách đã trả nhạc cụ và hoàn tất đơn này?')">
                                        <input type="hidden" name="rentalId" value="@rental.Id" />
                                        <button type="submit" class="btn btn-primary">
                                            🎯 Hoàn tất
                                        </button>
                                    </form>
                                }

                                @* 🔵 Khi đơn hoàn tất thì hiển thị nút Xóa thay vì Hủy *@
                                @if (rental.Status == "Completed")
                                {
                                    <form asp-action="Delete" method="post"
                                          onsubmit="return confirm('Bạn có chắc muốn xóa vĩnh viễn đơn này không?')">
                                        <input type="hidden" name="rentalId" value="@rental.Id" />
                                        <button type="submit" class="btn btn-dark">
                                            🗑 Xóa đơn
                                        </button>
                                    </form>
                                }
                                else if (rental.Status != "Cancelled" && rental.Status != "Completed")
                                {
                                    <form asp-action="Cancel" method="post" class="me-2"
                                          onsubmit="return confirm('Bạn có chắc muốn hủy đơn này không?')">
                                        <input type="hidden" name="rentalId" value="@rental.Id" />
                                        <button type="submit" class="btn btn-danger">
                                            ❌ Hủy đơn
                                        </button>
                                    </form>
                                }

                                @if (rental.Status == "Cancelled")
                                {
                                    <form asp-action="Delete" method="post"
                                          onsubmit="return confirm('Bạn có chắc muốn xóa vĩnh viễn đơn này không?')">
                                        <input type="hidden" name="rentalId" value="@rental.Id" />
                                        <button type="submit" class="btn btn-dark">
                                            🗑 Xóa đơn
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-warning text-center">Không có đơn thuê nhạc cụ nào!</div>
    }

    <a href="/Admin/Homepage/Dashboard" class="btn btn-secondary mt-4">🔙 Quay lại</a>
</div>

<!-- Modal bảo trì nhạc cụ -->
<div class="modal fade" id="maintenanceModal" tabindex="-1" aria-labelledby="maintenanceModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content bg-dark text-white">
            <div class="modal-header">
                <h5 class="modal-title" id="maintenanceModalLabel">🛠 Bảo trì nhạc cụ</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreateMaintenance" method="post">
                <div class="modal-body">
                    <div class="row">
                        @foreach (var p in allProducts ?? new List<DuAnBai3.Models.Product>())
                        {
                            var isRented = rentedIds.Contains(p.Id);
                            <div class="col-md-4 mb-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="ProductIds" value="@p.Id"
                                           id="prod-@p.Id"
                                    @(p.IsUnderMaintenance ? "checked" : "")
                                    @(isRented ? "disabled" : "") />
                                    <label class="form-check-label" for="prod-@p.Id"
                                           title="@(isRented ? "Nhạc cụ đang có khách thuê, phải hủy đơn trước khi bảo trì" : "")">
                                        @p.Name
                                        @if (p.IsUnderMaintenance)
                                        {
                                            <span class="text-warning">(Đang bảo trì)</span>
                                        }
                                        @if (isRented)
                                        {
                                            <span class="text-danger">(Đang thuê, không thể bảo trì)</span>
                                        }
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">✔ Xác nhận</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
    const maintenanceForm = document.querySelector('form[asp-action="CreateMaintenance"]');

    maintenanceForm.addEventListener('submit', function(e) {
        const checkedDisabled = maintenanceForm.querySelectorAll('input[type=checkbox]:checked:disabled');
        if (checkedDisabled.length > 0) {
            e.preventDefault();
            alert("Có nhạc cụ đang được thuê! Bạn phải hủy hết đơn trước khi bảo trì.");
        }
    });
</script>
