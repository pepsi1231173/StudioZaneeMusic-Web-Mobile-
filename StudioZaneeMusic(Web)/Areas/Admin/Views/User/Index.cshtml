@model IEnumerable<DuAnBai3.Models.UserViewModel>

@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>

<style>
    body {
        background: url('/images/background.jpg') no-repeat center center fixed;
        background-size: cover;
        font-family: 'Segoe UI', sans-serif;
    }

    html, body {
        overflow-x: hidden !important;
    }
    .user-management-container {
        background-color: rgba(255, 255, 255, 0.95);
        padding: 40px;
        border-radius: 16px;
        margin-top: 50px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    h2.title {
        color: #0d6efd;
        font-weight: bold;
        text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.2);
        text-align: center;
        margin-bottom: 30px;
    }

    .table thead th {
        background-color: #0d6efd;
        color: white;
        text-align: center;
        vertical-align: middle;
    }

    .table tbody td {
        vertical-align: middle;
    }

    .role-badge {
        font-size: 0.85rem;
        padding: 6px 10px;
        border-radius: 12px;
        margin: 2px;
        display: inline-block;
    }

    .btn-manage {
        background-color: #ffc107;
        border: none;
        font-weight: bold;
        transition: transform 0.2s ease;
    }

        .btn-manage:hover {
            background-color: #e0a800;
            transform: scale(1.05);
        }

    .btn-back {
        margin-top: 20px;
    }

    .table-hover tbody tr:hover {
        background-color: #f0f8ff;
    }
</style>

<div class="container user-management-container">
    <h2 class="title"><i class="fas fa-users-cog"></i> Quản lý người dùng</h2>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Họ tên</th>
                    <th>Vai trò</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>@user.FullName</td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                var roleClass = role switch
                                {
                                    "Admin" => "bg-danger",
                                    "Customer" => "bg-primary",
                                    _ => "bg-secondary"
                                };
                                <span class="role-badge badge @roleClass">@role</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-area="Admin"
                               asp-controller="User"
                               asp-action="ManageRoles"
                               asp-route-userId="@user.Id"
                               class="btn btn-sm btn-manage">
                                <i class="fas fa-user-shield"></i> Phân quyền
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="text-end">
        <a href="/Admin/Homepage/Dashboard" class="btn btn-secondary btn-back">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>
</div>
