@* File: Views/Shared/_LayoutAdmin.cshtml *@
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var username = HttpContextAccessor.HttpContext?.Session.GetString("username");
    var role = HttpContextAccessor.HttpContext?.Session.GetString("role");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zanee's Admin</title>

    <!-- Styles -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Lobster&family=Orbitron:wght@500&display=swap" rel="stylesheet" />

    @RenderSection("Styles", required: false)

    <style>
        body {
            margin: 0;
            padding-top: 70px;
            background: linear-gradient(120deg, #000000 0%, #1a1a1a 100%);
            color: #f1f1f1;
            font-family: 'Orbitron', sans-serif;
        }

        .navbar {
            background: rgba(0, 0, 0, 0.85);
            box-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
            border-bottom: 2px solid gold;
            font-family: 'Lobster', cursive;
            padding: 10px 30px;
        }

        .navbar-brand {
            color: gold !important;
            font-size: 40px;
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.6);
            animation: pulseBrand 3s infinite ease-in-out;
        }

        @@keyframes pulseBrand {
            0%, 100%

        {
            text-shadow: 0 0 8px rgba(255, 215, 0, 0.6);
        }

        50% {
            text-shadow: 0 0 20px rgba(255, 215, 0, 1);
        }

        }

        .nav-link {
            font-size: 17px;
            color: #eee !important;
            transition: all 0.3s ease;
        }

            .nav-link:hover {
                color: gold !important;
                text-shadow: 0 0 8px gold;
            }

        .btn-logout {
            background-color: crimson;
            color: white;
            border-radius: 6px;
            padding: 5px 14px;
            transition: 0.3s;
            font-weight: bold;
        }

            .btn-logout:hover {
                background-color: darkred;
                box-shadow: 0 0 10px red;
                transform: scale(1.05);
            }

        .container {
            animation: fadeInUp 0.6s ease;
        }
        @@keyframes fadeInUp {
            from

        {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .footer {
            margin-top: 50px;
            padding: 30px 0 20px;
            text-align: center;
            color: #bbb;
            font-size: 14px;
            border-top: 1px solid #444;
            background: radial-gradient(circle at top center, #111, transparent);
        }

            .footer:before {
                content: "🎧";
                font-size: 30px;
                display: block;
                margin-bottom: 10px;
                animation: beat 2s infinite;
            }
        @@keyframes beat {
            0%, 100%

        {
            transform: scale(1);
        }

        50% {
            transform: scale(1.15);
        }

        }

        #reloadButton {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: radial-gradient(circle, #0dcaf0, #0aa2c0);
            color: #000;
            border: none;
            padding: 14px 18px;
            font-size: 20px;
            border-radius: 50%;
            box-shadow: 0 0 15px rgba(0, 255, 255, 0.6);
            cursor: pointer;
            z-index: 9999;
            transition: transform 0.2s ease, box-shadow 0.3s ease;
        }

            #reloadButton:hover {
                transform: scale(1.15);
                box-shadow: 0 0 22px rgba(0, 255, 255, 0.9);
            }
    </style>
</head>
<body>
    <div class="wrapper d-flex flex-column min-vh-100">
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg fixed-top px-4">
            <a class="navbar-brand" href="/Admin/Homepage/Dashboard">🎵 Zanee Admin</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/Admin/Homepage/Dashboard"><i class="fas fa-home me-1"></i>Trang chủ</a>
                    </li>

                    <li class="nav-item position-relative">
                        <a class="nav-link" href="/Admin/Feedbacks/Index">
                            <i class="fas fa-comments me-1"></i> Phản hồi
                            <span id="feedbackBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger" style="display:none; width:20px; height:20px; font-size:12px; line-height:20px; text-align:center;">
                                0
                            </span>
                        </a>
                    </li>


                    @if (!string.IsNullOrEmpty(username))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="#" data-bs-toggle="modal" data-bs-target="#editUserModal">
                                <i class="fas fa-user-cog me-1"></i>@(role?.ToLower() == "admin" ? "Admin 👑" : username)
                            </a>
                        </li>
                        <li class="nav-item">
                            <form method="post" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/Homepage/Dashboard">
                                <button type="submit" class="nav-link btn btn-logout">
                                    <i class="fas fa-sign-out-alt me-1"></i>Đăng xuất
                                </button>
                            </form>
                        </li>
                    }
                </ul>
            </div>
        </nav>

        <!-- Main content -->
        <main class="container my-4 flex-grow-1">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="footer">
            © 2025 Zanee's Music Studio Corporation – Admin Dashboard. Made with 🎶
        </footer>
    </div>

    <!-- Scripts -->
    @RenderSection("Scripts", required: false)
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.js"></script>

    <button id="reloadButton" onclick="location.reload();" title="Tải lại trang">🔄</button>
    <script>
        // Kiểm tra số lượng feedback mới (cập nhật badge)
        async function checkNewFeedback() {
            try {
                const response = await fetch('/Admin/Feedbacks/GetNewFeedbackCount');
                const data = await response.json(); // { count: số feedback mới }

                const badge = document.getElementById('feedbackBadge');

                if (data.count > 0) {
                    badge.textContent = data.count;
                    badge.style.display = 'inline-block';
                } else {
                    badge.style.display = 'none';
                }
            } catch (err) {
                console.error('Lỗi khi kiểm tra feedback mới:', err);
            }
        }

        // Kiểm tra ngay khi load và mỗi 30 giây
        checkNewFeedback();
        setInterval(checkNewFeedback, 30000);
    </script>


</body>
</html>
