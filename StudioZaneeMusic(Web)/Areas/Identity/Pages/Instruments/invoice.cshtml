@page "{rental_id:int}"
@model DuAnBai3.Areas.Identity.Pages.Instruments.InvoiceModel
@{
    ViewData["Title"] = "Hóa Đơn Thuê Nhạc Cụ";
    Layout = "~/Areas/Identity/Pages/Shared/_Layout.cshtml";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<style>
    body {
        background: url('/images/instru-rental.jpg') no-repeat center/cover fixed;
        font-family: 'Arial',sans-serif;
    }

    .invoice-box {
        background: #fff;
        padding: 30px;
        border-radius: 10px;
        width: 90%;
        max-width: 1000px;
        margin: 50px auto;
        box-shadow: 0 0 15px rgba(0,0,0,.1);
    }

    .instrument-image {
        display: block;
        margin: 5px auto;
        width: 150px;
        border-radius: 5px;
    }

    .button-container {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 20px;
        margin-top: 20px;
    }

    .confirm-btn, .back-btn {
        text-decoration: none;
        background: linear-gradient(45deg,#ff6b6b,#f1c40f);
        color: #fff;
        border: none;
        border-radius: 25px;
        padding: 10px 18px;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        min-width: 160px;
        transition: .3s;
        box-shadow: 0 4px 8px rgba(0,0,0,.3);
        text-align: center;
    }

        .confirm-btn:hover, .back-btn:hover {
            background: linear-gradient(45deg,#f1c40f,#ff6b6b);
            transform: scale(1.05);
        }

    @@media print {
        .button-container {
            display: none !important;
        }

        body {
            background: #fff !important;
        }

        .invoice-box {
            box-shadow: none;
        }

        .music-title {
            color: #FFD700; /* màu vàng */
            font-family: 'Lobster', cursive; /* font kiểu âm nhạc */
            font-size: 3rem;
            text-align: center;
            font-weight: bold;
        }
    }
</style>

<div class="invoice-box">
    <h2 class="music-title">📝 HÓA ĐƠN THUÊ NHẠC CỤ</h2>

    @if (TempData["SuccessMessage"] is string msg)
    {
        <div class="alert alert-success fw-bold text-center">@msg</div>
    }

    @if (Model.Rental is null)
    {
        <p class="text-danger fw-bold text-center">❌ Không tìm thấy thông tin hóa đơn!</p>
        return;
    }

    <div class="table-responsive">
        <table class="table table-bordered text-center align-middle">
            <caption class="fw-bold">Thông tin khách hàng</caption>
            <tr><th>Tên khách hàng</th><td>@Model.Rental.CustomerName</td></tr>
            <tr><th>Số điện thoại</th><td>@Model.Rental.CustomerPhone</td></tr>
            <tr><th>Email</th><td>@Model.Rental.CustomerEmail</td></tr>
            <tr><th>Ngày thuê</th><td>@Model.Rental.RentalDate?.ToString("dd/MM/yyyy")</td></tr>
            <tr><th>Ngày tạo đơn</th><td>@Model.Rental.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td></tr>
        </table>
    </div>

    @if (Model.Instruments.Any())
    {
        <h3 class="text-center mt-4">🎸 Danh sách nhạc cụ thuê</h3>
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered text-center align-middle">
                <thead class="table-warning">
                    <tr><th>Nhạc cụ</th><th>Giá thuê/ngày</th><th>Thành tiền</th></tr>
                </thead>
                <tbody>
                    @foreach (var i in Model.Instruments)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@i.Name</div>
                                <img src="@Url.Content(i.ImageUrl ?? "/images/default-product.jpg")" alt="@i.Name" class="instrument-image" />
                            </td>
                            <td>@($"{i.Price:n0}".Replace(",", ".") + " VNĐ")</td>
                            <td>@($"{i.Price:n0}".Replace(",", ".") + " VNĐ")</td>
                        </tr>
                    }
                    <tr class="table-danger fw-bold">
                        <td colspan="2">Tổng tiền</td>
                        <td>@($"{Model.TotalPrice:n0}".Replace(",", ".") + " VNĐ")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning">⚠️ Không có nhạc cụ nào được chọn!</div>
    }

    <div class="button-container">
        <a href="/Identity/Homepage" class="back-btn">🏠 Về trang chủ</a>
    </div>
</div>
