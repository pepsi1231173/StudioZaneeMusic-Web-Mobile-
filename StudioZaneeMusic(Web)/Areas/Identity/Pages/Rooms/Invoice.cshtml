@page
@model DuAnBai3.Areas.Identity.Pages.Rooms.InvoiceModel
@{
    ViewData["Title"] = "Hóa đơn đặt phòng";
    Layout = "~/Areas/Identity/Pages/Shared/_Layout.cshtml";
    var booking = Model.Booking;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: url('/images/room_rental.gif') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Arial', sans-serif;
        }

        .invoice-box {
            background-color: rgba(255, 255, 255, 1);
            padding: 30px;
            border-radius: 10px;
            width: 70%;
            margin: 50px auto;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.1);
        }

            .invoice-box table {
                width: 100%;
                border-collapse: collapse;
            }

                .invoice-box table th, .invoice-box table td {
                    padding: 8px;
                    border: 1px solid #ddd;
                }

                .invoice-box table th {
                    background-color: #f7f7f7;
                    text-align: left;
                    width: 35%;
                }

                .invoice-box table td {
                    text-align: right;
                }

            .invoice-box h2 {
                text-align: center;
                margin-bottom: 30px;
            }

        .button-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
        }

        .confirm-btn, .back-btn {
            background: linear-gradient(45deg, #ff6b6b, #f1c40f);
            color: white;
            border: none;
            border-radius: 25px;
            padding: 10px 18px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            width: 48%;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
            text-align: center;
            display: inline-block;
            text-decoration: none;
            line-height: 1.5;
        }

            .confirm-btn:hover, .back-btn:hover {
                background: linear-gradient(45deg, #f1c40f, #ff6b6b);
                transform: scale(1.05);
                text-decoration: none;
                color: white;
            }

        .music-title {
            color: #FFD700; /* màu vàng */
            font-family: 'Lobster', cursive; /* font kiểu âm nhạc */
            font-size: 3rem;
            text-align: center;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="invoice-box">
        <h2> class="music-title">📝 HÓA ĐƠN ĐẶT PHÒNG</h2>
        <p><strong>Mã đơn:</strong> #@Model.Booking.DailyBookingNumber.ToString("D4")</p>
        <table>
            <tr><th>Tên khách hàng</th><td>@booking.CustomerName</td></tr>
            <tr><th>Số điện thoại</th><td>@booking.CustomerPhone</td></tr>
            <tr><th>Email</th><td>@booking.CustomerEmail</td></tr>
            <tr><th>Ngày thuê</th><td>@booking.RentalDate.ToString("yyyy-MM-dd")</td></tr>
            <tr><th>Giờ bắt đầu</th><td>@booking.StartTime.ToString(@"hh\:mm")</td></tr>
            <tr><th>Thời gian thuê</th><td>@booking.RentalDuration giờ</td></tr>
            <tr><th>Số khách</th><td>@booking.GuestCount khách</td></tr>
            <tr><th>Phòng tập</th><td>@booking.RoomId</td></tr>
            <tr>
                <th>Giá chi tiết</th>
                <td>
                    @Model.NormalHours giờ thường x @Model.PricePerHour.ToString("N0") VNĐ<br />
                    @Model.DiscountHours giờ khuyến mãi x @Model.DiscountPrice.ToString("N0") VNĐ
                </td>
            </tr>
            @if (Model.ExtraGuests > 0)
            {
                <tr>
                    <th>Phụ thu khách</th>
                    <td>@Model.ExtraGuests khách x @Model.ExtraGuestFee.ToString("N0") = <b>@Model.ExtraFee.ToString("N0") VNĐ</b></td>
                </tr>
            }
            <tr>
                <th class="text-danger">Tổng tiền</th>
                <td class="text-danger"><b>@Model.FinalPrice.ToString("N0") VNĐ</b></td>
            </tr>
        </table>
   
        <div class="button-container">

            <a asp-area="Identity" asp-page="/Homepage/Index" class="confirm-btn">🏠 Quay lại trang chủ</a>
        </div>
    </div>
</body>
</html>