@page "/Music/InvoiceMusic/{id:int}"
@model DuAnBai3.Pages.MusicConfirmModel
@{
    ViewData["Title"] = "Xác Nhận Yêu Cầu";
    Layout = "~/Areas/Identity/Pages/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Lobster&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

<style>
    body {
        background: url('/images/day_background.gif') no-repeat center center fixed;
        background-size: cover;
        color: white;
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
    }

    .container {
        margin-top: 150px !important;
        margin-bottom: 100px !important;
        background: rgba(32, 140, 154, 0.7);
        border-radius: 10px;
        padding: 40px;
        max-width: 600px;
        width: 90%;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.5);
        text-align: center;
        margin: 40px auto;
    }

    .title {
        font-family: 'Lobster', cursive;
        font-weight: bold;
        letter-spacing: 2.2px;
        color: #FFD700;
        text-shadow: 3px 3px 8px rgba(17, 17, 17, 0.7);
        font-size: 40px;
    }

    .message, td, th {
        font-size: 1.2rem;
    }

    td {
        padding: 10px;
        text-align: right;
        padding-left: 100px;
    }

    th {
        padding-left: 30px;
        color: #FFD700;
        font-weight: bold;
    }

    .btn {
        background: linear-gradient(45deg, #ff0066, #ffcc00);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 18px;
        font-size: 1.1rem;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn:hover {
            background: linear-gradient(45deg, #ffcc00, #ff0066);
            transform: scale(1.05);
        }
</style>

<div class="container">
    <h2 class="title">🎼 Dịch Vụ Làm Nhạc 🎶</h2>
    <p class="message2">Cảm ơn bạn đã gửi yêu cầu! Dưới đây là thông tin bạn đã nhập:</p>

    <table class="message">
        <tr>
            <th>Thể loại nhạc: </th>
            <td>@Model.MusicRequest.MusicGenre</td>
        </tr>
        <tr>
            <th>Mô tả yêu cầu: </th>
            <td>@Model.MusicRequest.MusicDescription</td>
        </tr>
        <tr>
            <th>Họ tên khách hàng: </th>
            <td>@Model.MusicRequest.CustomerName</td>
        </tr>
        <tr>
            <th>Email: </th>
            <td>@Model.MusicRequest.CustomerEmail</td>
        </tr>
        <tr>
            <th>Số điện thoại: </th>
            <td>@Model.MusicRequest.CustomerPhone</td>
        </tr>
    </table>

    <a asp-page="/Index" class="btn">Quay lại trang chủ</a>
</div>
