@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zanee's Music Studio</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body {
            background: url('https://source.unsplash.com/1600x900/?music,studio') no-repeat center center fixed;
            background-size: cover;
            color: white;
        }

        .login-container {
            max-width: 400px;
            margin: 100px auto;
            margin-bottom: 20px;
            padding: 30px;
            background: rgba(0, 0, 0, 0.7);
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(255, 255, 255, 0.2);
        }

            .login-container h2 {
                text-align: center;
                margin-bottom: 20px;
            }

        .form-control {
            background: transparent;
            color: white;
            border: 1px solid #f8d210;
        }

            .form-control::placeholder {
                color: rgba(255, 255, 255, 0.6);
            }

        .btn-loginn {
            margin-top: 20px;
            margin-bottom: 20px;
            background: #f8d210;
            color: black;
            width: 100%;
        }

            .btn-loginn:hover {
                background: rgb(214, 181, 49);
            }

        .text-muted {
            color: white !important;
            text-align: center;
            display: block;
        }

        a {
            color: #f8d210;
            text-decoration: none;
        }

            a:hover {
                text-decoration: underline;
            }

        body {
            background: url('/images/background.jpg') no-repeat center center fixed !important;
            background-size: cover !important;
            margin: 0;
            padding-top: 0 !important;
        }

        .main-content {
            padding-top: 100px;
            padding-bottom: 50px;
        }

        .btn-custom {
            background-color: #c67e2e;
            border: none;
            padding: 15px 30px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 8px;
            color: white;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4);
            transition: 0.3s;
        }

            .btn-custom i {
                margin-right: 10px;
            }

            .btn-custom:hover {
                filter: brightness(1.2);
                transform: scale(1.05);
            }

        .section {
            margin-top: 80px;
        }

            .section h4 {
                font-weight: bold;
                color: #ffc107;
                margin-bottom: 15px;
            }

            .section p,
            .section ul,
            .section li {
                font-size: 16px;
                color: #f1f1f1;
            }

            .section ul {
                list-style: none;
                padding-left: 0;
            }

        .footer-social a {
            color: white;
            margin: 0 10px;
            font-size: 22px;
            transition: 0.3s;
        }

            .footer-social a:hover {
                color: #ffc107;
            }

        .footer {
            margin-top: 50px;
            font-size: 14px;
            color: #ccc;
        }

    </style>
</head>
<div class="login-container mt-n4">
    <h2><i class="fa fa-user-circle"></i> LOGIN </h2>

    <form id="account" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        @* Hiển thị lỗi đăng nhập không thành công *@
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <div class="mb-3">
            <label asp-for="Input.Email" class="form-label">Email</label>
            <input asp-for="Input.Email" class="form-control" placeholder="Nhập email" autocomplete="username" aria-required="true" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Input.Password" class="form-label">Mật khẩu</label>
            <input asp-for="Input.Password" type="password" class="form-control" placeholder="Nhập mật khẩu" autocomplete="current-password" aria-required="true" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="Input.RememberMe" class="form-check-input" />
            <label asp-for="Input.RememberMe" class="form-check-label">Ghi nhớ đăng nhập</label>
        </div>

        <button type="submit" class="btn btn-loginn w-100"><i class="fa fa-sign-in-alt"></i> Đăng nhập</button>

        <p class="text-muted mt-3">
            Bạn chưa có tài khoản?
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Đăng ký ngay</a>
        </p>
    </form>
</div>

<div class="row section">
    <div class="col-md-4">
        <h4>ZANEE'S MUSIC STUDIO</h4>
        <p>Studio giúp đáp ứng mọi đam mê về âm nhạc của bạn.</p>
        <p>Đến trải nghiệm các dịch vụ chuyên nghiệp của chúng tôi ngay hôm nay!</p>
    </div>
    <div class="col-md-4">
        <h4>LIÊN KẾT NHANH</h4>
        <ul>
            <li>Cho thuê phòng tập</li>
            <li>Cho thuê nhạc cụ</li>
            <li>Dịch vụ thu âm</li>
            <li>Dịch vụ làm nhạc</li>
        </ul>
    </div>
    <div class="col-md-4">
        <h4>KẾT NỐI VỚI CHÚNG TÔI</h4>
        <div class="footer-social">
            <a href="#"><i class="fab fa-facebook-f"></i></a>
            <a href="#"><i class="fab fa-tiktok"></i></a>
            <a href="#"><i class="fab fa-instagram"></i></a>
        </div>
    </div>
</div>
<div class="footer mt-5">
    © 2025 Zanee's Music Studio Corporation. All rights reserved.
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
