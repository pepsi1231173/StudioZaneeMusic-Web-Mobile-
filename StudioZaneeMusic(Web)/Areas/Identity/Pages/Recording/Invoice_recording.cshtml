@page "/Identity/Recording/InvoiceRecording/{id:int}"
@model DuAnBai3.Areas.Identity.Pages.Recording.InvoiceRecordingModel
@{
    ViewData["Title"] = "Hóa đơn đặt thu âm";
    Layout = "~/Areas/Identity/Pages/Shared/_Layout.cshtml";
    var booking = Model.Booking;

 string GetStatusText(string status) => status?.ToLower() switch
    {
        "pending" => "Chờ duyệt",
        "confirmed" => "Đã xác nhận",
        "canceled" => "Đã hủy",
        _ => "Không xác định"
    };
    string GetBadgeColor(string status) => status?.ToLower() switch
    {
        "pending" => "warning",
        "confirmed" => "success",
        "canceled" => "danger",
        _ => "secondary"
    };
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Lobster&display=swap" rel="stylesheet">
    <style>
        body {
            background: url('/images/night_background.gif') no-repeat center center fixed;
            background-size: cover;
            font-family: 'Arial', sans-serif;
        }

        .invoice-box {
            background-color: rgba(255, 255, 255, 0.95);
            padding: 30px;
            border-radius: 10px;
            width: 70%;
            margin: 50px auto;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.1);
        }

        .invoice-box table {
            width: 100%;
            border-collapse: collapse;
        }

        .invoice-box table th,
        .invoice-box table td {
            padding: 8px;
            border: 1px solid #ddd;
        }

        .invoice-box table th {
            background-color: #f7f7f7;
            text-align: left;
            width: 35%;
        }

        .invoice-box table td {
            text-align: right;
        }

        .invoice-box h2 {
            text-align: center;
            margin-bottom: 30px;
        }

        .button-container {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
        }

        .btn-custom {
            background: linear-gradient(45deg, #ff6b6b, #f1c40f);
            color: white;
            border: none;
            border-radius: 25px;
            padding: 10px 18px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            width: 48%;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
            text-align: center;
            text-decoration: none;
        }

        .btn-custom:hover {
            background: linear-gradient(45deg, #f1c40f, #ff6b6b);
            transform: scale(1.05);
            text-decoration: none;
            color: white;
        }

        .music-title {
            color: #FFD700; /* màu vàng */
            font-family: 'Lobster', cursive; /* font kiểu âm nhạc */
            font-size: 3rem;
            text-align: center;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="invoice-box">
        <h2 class="music-title">🎵 HÓA ĐƠN THU ÂM</h2>

        @if (booking != null)
        {
            
                var start = booking.RecordingTime;
                var end = start + TimeSpan.FromHours(booking.Duration);
            var statusText = GetStatusText(booking.Status);
            var badgeColor = GetBadgeColor(booking.Status);
           

            <p><strong>Mã đơn:</strong> #@booking.Id.ToString("D4")</p>
            <table>
                <tr><th>Tên khách hàng</th><td>@booking.CustomerName</td></tr>
                <tr><th>Số điện thoại</th><td>@booking.CustomerPhone</td></tr>
                <tr><th>Email</th><td>@booking.CustomerEmail</td></tr>
                <tr><th>Gói dịch vụ</th><td>@booking.RecordingPackage</td></tr>
                <tr><th>Ngày thu âm</th><td>@booking.RecordingDate.ToString("dd/MM/yyyy")</td></tr>
                <tr><th>Giờ thu âm</th><td>@start.ToString(@"hh\:mm") - @end.ToString(@"hh\:mm")</td></tr>
                <tr><th>Giá</th><td>@booking.Price.ToString("N0") VNĐ</td></tr>
                <tr>
                    <th>Trạng thái</th>
                    <td><span class="badge bg-@badgeColor">@statusText</span></td>
                </tr>
                <tr><th>Ngày tạo đơn</th><td>@booking.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td></tr>
                <tr>
                    <th class="text-danger">Tổng tiền</th>
                    <td class="text-danger"><b>@booking.Price.ToString("N0") VNĐ</b></td>
                </tr>
            </table>

            <div class="button-container">
                <a asp-area="Identity" asp-page="/Homepage/Index" class="btn-custom">🏠 Quay lại trang chủ</a>
            </div>
        }
        else
        {
            <p class="text-danger text-center">Không tìm thấy đơn thu âm.</p>
        }
    </div>
</body>
</html>
