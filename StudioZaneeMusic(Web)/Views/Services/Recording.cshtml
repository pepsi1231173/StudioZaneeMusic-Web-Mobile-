@{
    ViewData["Title"] = "Dịch vụ Thu âm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Lobster&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<style>
    body {
        background: url('/images/rooms/micro.jpg') no-repeat center center fixed;
        background-size: cover; /* giữ ảnh phủ full nền */
        background-position: center center; /* căn giữa ảnh */
        margin: 0;
        padding: 0;
        font-family: 'Poppins', sans-serif;
        color: white;
        position: relative;
    }


    /* Container nội dung lên trên overlay */
    .contact-container {
        position: relative;
        z-index: 1; /* đảm bảo nằm trên lớp overlay */
        margin: 50px auto;
        max-width: 800px;
        margin-top: 100px;
        background: rgba(0, 0, 0, 0.75);
        padding: 40px 30px;
        border-radius: 15px;
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.7);
    }


    h1 {
        font-family: 'Lobster', cursive;
        font-size: 42px;
        text-align: center;
        margin-bottom: 30px;
        color: gold;
        text-shadow: 0 0 10px #ffd700;
    }

    p, ul, li, h3 {
        color: #eee;
        font-size: 18px;
        line-height: 1.6;
    }

    ul {
        padding-left: 20px;
    }

    hr {
        border-color: gold;
        margin: 30px 0;
    }

    .custom-text {
        text-align: center;
        font-weight: bold;
        font-size: 20px;
        margin-top: 20px;
        color: #ffd700;
        text-shadow: 0 0 5px #ffcc00;
    }
</style>

<h1>🎧 Dịch vụ Thu âm chuyên nghiệp tại Zanee's Music Studio</h1>

<p>
    Thu âm chất lượng cao với phòng thu hiện đại, thiết bị tiên tiến, kỹ thuật viên giàu kinh nghiệm.
    Chúng tôi hỗ trợ thu âm đa dạng thể loại: Pop, Rock, Ballad, EDM, Acoustic,...
</p>

<h3>Chúng tôi cung cấp:</h3>
<ul>
    <li>Phòng thu được cách âm tiêu chuẩn quốc tế</li>
    <li>Trang thiết bị thu âm hiện đại: micro, mixer, sound card cao cấp</li>
    <li>Kỹ thuật viên thu âm chuyên nghiệp hỗ trợ xuyên suốt quá trình</li>
    <li>Dịch vụ chỉnh sửa âm thanh, mix & master chất lượng</li>
</ul>

<p>
    Hãy để chúng tôi giúp bạn lưu giữ những giai điệu tuyệt vời nhất!
</p>

<a class="btn btn-warning" href="/Contact">Liên hệ để đặt lịch thu âm</a>
